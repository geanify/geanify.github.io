<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/modern-gaming.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
</head>
<body class="dark-theme">
    <%- include('partials/navbar') %>

    <main class="container-fluid px-0">
        <section class="py-section">
            <div class="container">
                <div class="row">
                    <div class="col-lg-8 mx-auto">
                        <div class="card floating-card">
                            <div class="card-body">
                                <div class="text-center mb-5">
                                    <div class="feature-icon primary-bg mx-auto mb-3">
                                        <i class="fas fa-info-circle"></i>
                                    </div>
                                    <h1 class="dashboard-title text-glow mb-3">About <span class="text-accent">Web Herald</span></h1>
                                    <p class="lead text-secondary"><%= content %></p>
                                </div>
                                
                                <div class="row g-4 mb-5">
                                    <div class="col-md-6">
                                        <h3 class="text-accent mb-4">
                                            <i class="fas fa-star me-2"></i>Gaming Features
                                        </h3>
                                        <div class="list-group list-group-flush bg-transparent">
                                            <div class="list-group-item bg-transparent border-gaming text-secondary d-flex align-items-center">
                                                <i class="fas fa-bolt text-warning me-3"></i>
                                                Lightning-fast server deployment
                                            </div>
                                            <div class="list-group-item bg-transparent border-gaming text-secondary d-flex align-items-center">
                                                <i class="fas fa-gamepad text-primary me-3"></i>
                                                Multi-game server support
                                            </div>
                                            <div class="list-group-item bg-transparent border-gaming text-secondary d-flex align-items-center">
                                                <i class="fas fa-mobile-alt text-success me-3"></i>
                                                Mobile-responsive dashboard
                                            </div>
                                            <div class="list-group-item bg-transparent border-gaming text-secondary d-flex align-items-center">
                                                <i class="fas fa-shield-alt text-info me-3"></i>
                                                DDoS protection included
                                            </div>
                                            <div class="list-group-item bg-transparent border-gaming text-secondary d-flex align-items-center">
                                                <i class="fas fa-headset text-accent me-3"></i>
                                                24/7 gamer support
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="col-md-6">
                                        <h3 class="text-accent mb-4">
                                            <i class="fas fa-rocket me-2"></i>Quick Setup
                                        </h3>
                                        <div class="bg-tertiary p-4 rounded">
                                            <ol class="text-secondary mb-0">
                                                <li class="mb-2">
                                                    <i class="fas fa-download text-primary me-2"></i>
                                                    Install dependencies: <code class="text-accent">npm install</code>
                                                </li>
                                                <li class="mb-2">
                                                    <i class="fas fa-play text-success me-2"></i>
                                                    Start dev server: <code class="text-accent">npm run dev</code>
                                                </li>
                                                <li class="mb-0">
                                                    <i class="fas fa-cloud-upload text-warning me-2"></i>
                                                    Deploy to production: <code class="text-accent">npm run deploy</code>
                                                </li>
                                            </ol>
                                        </div>
                                    </div>
                                </div>

                                <!-- Support Section -->
                                <div class="text-center bg-tertiary p-4 rounded mb-4">
                                    <h4 class="text-accent mb-3">
                                        <i class="fas fa-life-ring me-2"></i>Need Help?
                                    </h4>
                                    <p class="text-secondary mb-4">Our gaming support team is here to help you dominate!</p>
                                    <div class="row g-3">
                                        <div class="col-md-4">
                                            <a href="mailto:support@web-herald.com" class="btn btn-outline-primary w-100">
                                                <i class="fas fa-envelope me-2"></i>Email Support
                                            </a>
                                        </div>
                                        <div class="col-md-4">
                                            <a href="#" class="btn btn-outline-success w-100">
                                                <i class="fab fa-discord me-2"></i>Discord Community
                                            </a>
                                        </div>
                                        <div class="col-md-4">
                                            <a href="#" class="btn btn-outline-info w-100">
                                                <i class="fas fa-book me-2"></i>Documentation
                                            </a>
                                        </div>
                                    </div>
                                </div>

                                <div class="text-center">
                                    <a href="/" class="btn btn-accent me-3">
                                        <i class="fas fa-home me-2"></i>Back to Gaming Hub
                                    </a>
                                    <a href="/servers" class="btn btn-outline-accent">
                                        <i class="fas fa-server me-2"></i>Manage Servers
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Add gaming hover effects
        document.addEventListener('DOMContentLoaded', function() {
            const listItems = document.querySelectorAll('.list-group-item');
            listItems.forEach(item => {
                item.addEventListener('mouseenter', function() {
                    this.style.transform = 'translateX(10px)';
                    this.style.background = 'var(--bg-hover)';
                });
                item.addEventListener('mouseleave', function() {
                    this.style.transform = 'translateX(0)';
                    this.style.background = 'transparent';
                });
            });
        });
    </script>
</body>
</html> 