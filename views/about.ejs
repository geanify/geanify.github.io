<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('partials/navbar') %>

    <main class="container mt-4">
        <div class="row">
            <div class="col-lg-8 mx-auto">
                <h1 class="mb-4">About Web Herald</h1>
                <p class="lead"><%= content %></p>
                
                <h3>Features</h3>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item">⚡ Fast Express.js server</li>
                    <li class="list-group-item">🎨 EJS templating engine</li>
                    <li class="list-group-item">📱 Responsive Bootstrap design</li>
                    <li class="list-group-item">🚀 Easy deployment script</li>
                    <li class="list-group-item">🔧 Development-ready setup</li>
                </ul>

                <h3 class="mt-4">Getting Started</h3>
                <ol>
                    <li>Install dependencies: <code>npm install</code></li>
                    <li>Start development server: <code>npm run dev</code></li>
                    <li>Deploy to production: <code>npm run deploy user@hostname</code></li>
                </ol>

                <div class="mt-4">
                    <a href="/" class="btn btn-secondary">← Back to Home</a>
                </div>
            </div>
        </div>
    </main>

    <%- include('partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html> 