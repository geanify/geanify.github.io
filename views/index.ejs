<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
</head>
<body class="dark-theme">
    <%- include('partials/navbar') %>

    <main class="container-fluid px-0">
        <!-- Hero Section -->
        <section class="hero-section">
            <div class="hero-overlay">
                <div class="container">
                    <div class="row align-items-center min-vh-75">
                        <div class="col-lg-6">
                            <div class="hero-content">
                                <h1 class="hero-title mb-4">
                                    <span class="accent-text">Web</span> Herald
                                </h1>
                                <p class="hero-subtitle mb-4">
                                    Modern web applications built with cutting-edge technology and elegant design
                                </p>
                                <p class="hero-description mb-5">
                                    Experience the power of Express.js combined with dynamic EJS templating in a beautiful, responsive interface that adapts to your needs.
                                </p>
                                <div class="hero-actions">
                                    <a href="/about" class="btn btn-primary btn-lg me-3">
                                        <i class="fas fa-rocket me-2"></i>Get Started
                                    </a>
                                    <a href="#features" class="btn btn-outline-accent btn-lg">
                                        <i class="fas fa-info-circle me-2"></i>Learn More
                                    </a>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-6">
                            <div class="hero-visual">
                                <div class="floating-cards">
                                    <div class="floating-card card-1">
                                        <i class="fab fa-node-js"></i>
                                    </div>
                                    <div class="floating-card card-2">
                                        <i class="fas fa-code"></i>
                                    </div>
                                    <div class="floating-card card-3">
                                        <i class="fas fa-mobile-alt"></i>
                                    </div>
                                    <div class="floating-card card-4">
                                        <i class="fas fa-rocket"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Features Section -->
        <section id="features" class="features-section py-5">
            <div class="container">
                <div class="row">
                    <div class="col-12 text-center mb-5">
                        <h2 class="section-title">
                            <span class="primary-text">Powerful</span> Features
                        </h2>
                        <p class="section-subtitle">Everything you need to build modern web applications</p>
                    </div>
                </div>
                <div class="row g-4">
                    <div class="col-md-4">
                        <div class="feature-card">
                            <div class="feature-icon primary-bg">
                                <i class="fab fa-node-js"></i>
                            </div>
                            <h5 class="feature-title">Express.js</h5>
                            <p class="feature-description">
                                Fast, unopinionated, minimalist web framework for Node.js with robust routing and middleware support.
                            </p>
                            <div class="feature-tags">
                                <span class="tag">Fast</span>
                                <span class="tag">Scalable</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="feature-card">
                            <div class="feature-icon secondary-bg">
                                <i class="fas fa-code"></i>
                            </div>
                            <h5 class="feature-title">EJS Templates</h5>
                            <p class="feature-description">
                                Embedded JavaScript templating for dynamic content generation with clean, maintainable code.
                            </p>
                            <div class="feature-tags">
                                <span class="tag">Dynamic</span>
                                <span class="tag">Flexible</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="feature-card">
                            <div class="feature-icon accent-bg">
                                <i class="fas fa-mobile-alt"></i>
                            </div>
                            <h5 class="feature-title">Responsive Design</h5>
                            <p class="feature-description">
                                Beautiful, mobile-first responsive design that looks great on all devices and screen sizes.
                            </p>
                            <div class="feature-tags">
                                <span class="tag">Mobile-First</span>
                                <span class="tag">Modern</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Stats Section -->
        <section class="stats-section py-5">
            <div class="container">
                <div class="row g-4">
                    <div class="col-md-3 col-sm-6">
                        <div class="stat-card">
                            <div class="stat-icon success-bg">
                                <i class="fas fa-bolt"></i>
                            </div>
                            <div class="stat-content">
                                <h3 class="stat-number">99.9%</h3>
                                <p class="stat-label">Uptime</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6">
                        <div class="stat-card">
                            <div class="stat-icon primary-bg">
                                <i class="fas fa-users"></i>
                            </div>
                            <div class="stat-content">
                                <h3 class="stat-number">1000+</h3>
                                <p class="stat-label">Users</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6">
                        <div class="stat-card">
                            <div class="stat-icon warning-bg">
                                <i class="fas fa-code-branch"></i>
                            </div>
                            <div class="stat-content">
                                <h3 class="stat-number">50+</h3>
                                <p class="stat-label">Deployments</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6">
                        <div class="stat-card">
                            <div class="stat-icon secondary-bg">
                                <i class="fas fa-clock"></i>
                            </div>
                            <div class="stat-content">
                                <h3 class="stat-number">24/7</h3>
                                <p class="stat-label">Support</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- CTA Section -->
        <section class="cta-section py-5">
            <div class="container">
                <div class="row">
                    <div class="col-lg-8 mx-auto text-center">
                        <h2 class="cta-title mb-4">Ready to Get Started?</h2>
                        <p class="cta-description mb-5">
                            Deploy your application in minutes with our automated deployment script. 
                            No complex configuration, just simple commands.
                        </p>
                        <div class="cta-actions">
                            <a href="/about" class="btn btn-accent btn-lg me-3">
                                <i class="fas fa-play me-2"></i>Start Building
                            </a>
                            <a href="#" class="btn btn-outline-neutral btn-lg">
                                <i class="fab fa-github me-2"></i>View on GitHub
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Add floating animation to cards
        document.addEventListener('DOMContentLoaded', function() {
            const floatingCards = document.querySelectorAll('.floating-card');
            floatingCards.forEach((card, index) => {
                card.style.animationDelay = `${index * 0.5}s`;
            });
        });
    </script>
</body>
</html> 