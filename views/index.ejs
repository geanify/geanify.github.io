    }
    .projects-title {
      font-size: 1.7rem;
      color: var(--accent);
      margin-bottom: 1.5rem;
      text-align: center;
      font-weight: 800;
      letter-spacing: 1px;
      text-shadow: 0 2px 8px var(--overlay-background);
    }
    .projects-list {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(290px, 1fr));
      gap: 2rem;
      justify-content: center;
      max-width: 100vw;
      box-sizing: border-box;
    }
    .project-card-link {
      display: block;
      text-decoration: none !important;
      color: inherit !important;
      cursor: pointer;
    }
    .project-card-link:visited,
    .project-card-link:active,
    .project-card-link:focus {
      color: inherit !important;
      text-decoration: none !important;
      outline: none;
    }
    .project-card-link .project-card,
    .project-card-link .project-card:hover {
      box-shadow: 0 0 24px 4px #3c40c6, 0 0 8px 2px #f53b57;
      border-color: #ffd32a;
      background: #1a0033;
      transition: box-shadow 0.2s, border-color 0.2s, background 0.2s;
    }
    .project-card {
      width: 100%;
      max-width: calc(100vw - 2.5rem);
      box-sizing: border-box;
      background: var(--background-dark-highlight);
      border-radius: 18px;
      box-shadow: 0 2px 12px var(--overlay-background);
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 1.5rem 1rem 1.2rem 1rem;
      transition: transform 0.15s, box-shadow 0.15s;
      border: 2px solid transparent;
      min-width: 0;
      position: relative;
      overflow: hidden;
    }
    .project-card:hover,
    .project-card-flashy-neon {
      transform: scale(1.08) rotate(-2deg);
      z-index: 2;
    }
    .project-image {
      width: 90px;
      height: 90px;
      border-radius: 12px;
      background: var(--neutral-highlight);
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      box-shadow: 0 2px 8px var(--overlay-background);
    }
    .project-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      background: var(--neutral-highlight);
    }
    .project-title {
      font-size: 1.2rem;
      color: var(--primary);
      font-weight: 700;
      margin-bottom: 0.5rem;
      text-align: center;
      letter-spacing: 0.5px;
    }
    .project-description {
      color: var(--neutral-highlight);
      font-size: 1rem;
      text-align: center;
      margin-bottom: 0.5rem;
      font-weight: 500;
    }
    .view-project-btn {
      margin-top: 0.7rem;
      padding: 0.5rem 1.2rem;
      background: var(--accent);
      color: var(--accent-text);
      border: none;
      border-radius: 7px;
      font-weight: 700;
      font-size: 1rem;
      cursor: pointer;
      box-shadow: 0 1px 6px var(--overlay-background);
      transition: background 0.18s, color 0.18s, box-shadow 0.18s;
      letter-spacing: 0.5px;
    }
    .view-project-btn:hover, .view-project-btn:focus {
      background: var(--primary);
      color: var(--primary-text);
      box-shadow: 0 2px 12px var(--primary-highlight);
    }
    footer {
      text-align: center;
      padding: 1.5rem 0 1rem 0;
      background: var(--background-dark-highlight);
      color: var(--neutral);
      font-size: var(--small-font-size);
      letter-spacing: 0.5px;
      box-shadow: 0 -2px 12px var(--background-dark-highlight);
      margin-top: 3rem;
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
    }
    @media (max-width: 900px) {
      .projects-list {
         flex-direction: column;
         align-items: center;
         max-width: 100vw;
      }
      .project-card {
         width: 100%;
         max-width: calc(100vw - 2.5rem);
         box-sizing: border-box;
      }
    }
    @media (max-width: 600px) {
      .container {
         padding: 1rem 0.5rem 0.5rem 0.5rem;
         max-width: 100vw;
      }
      .hero-underline {
         width: 50px;
         height: 4px;
      }
      .logo {
         width: 70px;
         height: 70px;
      }
      .projects-title {
         font-size: 1.2rem;
      }
      .navbar {
         max-width: 100vw;
         min-height: 80px;
      }
      .navbar-content {
         max-width: 100vw;
         min-height: 80px;
         padding: 0.2rem 0.5rem;
      }
      .projects-list {
         max-width: 100vw;
         grid-template-columns: 1fr;
      }
      .project-card {
         width: 100%;
         max-width: calc(100vw - 1.2rem);
         margin-left: auto;
         margin-right: auto;
      }
    }
    .highlight-section {
      box-shadow: 0 0 0 4px var(--accent), 0 2px 24px var(--primary-highlight);
      transition: box-shadow 0.3s;
      z-index: 10;
      border-radius: 18px;
    }
    .btn-linklike {
      display: inline-block;
      text-align: center;
      text-decoration: none !important;
      appearance: none;
      -webkit-appearance: none;
      -moz-appearance: none;
      border: none;
      outline: none;
      background: var(--secondary);
      color: var(--secondary-text);
      font: inherit;
      cursor: pointer;
      padding: 0.95rem 2.3rem;
      font-size: 1.1rem;
      border-radius: 10px;
      font-weight: 700;
      box-shadow: 0 2px 12px var(--overlay-background);
      min-width: 170px;
      margin-bottom: 0.5rem;
      letter-spacing: 0.5px;
      transition: background 0.18s, color 0.18s, box-shadow 0.18s, transform 0.18s;
    }
    .btn-linklike:hover, .btn-linklike:focus {
      background: var(--secondary-highlight);
      color: var(--accent-text);
      transform: translateY(-2px) scale(1.04);
      box-shadow: 0 4px 18px var(--secondary-highlight);
      text-decoration: none !important;
    }
    .logo-tap-neon {
      box-shadow: 0 0 32px 8px var(--neon-pink), 0 0 16px 4px var(--neon-blue), 0 0 12px 4px var(--neon-yellow) !important;
      filter: brightness(1.3) saturate(1.5) drop-shadow(0 0 12px var(--neon-yellow));
      background: var(--neon-bg) !important;
      transition: box-shadow 0.2s, background 0.2s, filter 0.2s;
    }
    .project-card-flashy-neon {
      box-shadow: 0 0 32px 8px var(--neon-pink), 0 0 32px 8px var(--neon-blue), 0 0 24px 8px var(--neon-yellow), 0 0 16px 8px var(--neon-green) !important;
      filter: brightness(1.3) saturate(1.5) drop-shadow(0 0 12px var(--neon-yellow));
      background: linear-gradient(120deg, var(--neon-blue) 0%, #1a0033 100%);
      animation: project-card-neon-bg-blue 0.5s linear;
      transition: box-shadow 0.2s, background 0.2s, filter 0.2s;
    }
    @keyframes project-card-neon-bg-blue {
      0% { background: linear-gradient(120deg, var(--neon-yellow) 0%, var(--neon-pink) 50%, var(--neon-blue) 100%); }
      100% { background: linear-gradient(120deg, var(--neon-blue) 0%, #1a0033 100%); }
    }
    .project-card-flashy-neon::after {
      content: '';
      position: absolute;
      top: -6px; left: -6px; right: -6px; bottom: -6px;
      border-radius: 22px;
      pointer-events: none;
      z-index: 10;
      border: 3px solid #00f0ff;
      box-shadow: 0 0 32px 12px #00f0ff, 0 0 24px 8px #3c40c6;
      opacity: 1;
      filter: blur(2px) brightness(1.5) saturate(2);
      transition: box-shadow 0.2s, border-color 0.2s, opacity 0.2s;
    }
    @media (min-width: 1000px) {
      .side-banners { 
        display: flex !important; 
        position: fixed;
        top: 50%;
        transform: translateY(-50%);
        z-index: 50;
        width: 320px;
        max-width: 22vw;
      }
      .side-banners:first-of-type {
        left: 0;
        margin-left: 0 !important;
        margin-right: 0 !important;
        align-items: flex-start;
      }
      .side-banners:last-of-type {
        right: 0;
        margin-right: 0 !important;
        margin-left: 0 !important;
        align-items: flex-end;
      }
      .projects-list-wrapper {
        margin-left: 340px !important;
        margin-right: 340px !important;
        width: auto !important;
      }
      .projects-list { grid-template-columns: repeat(auto-fit, minmax(290px, 1fr)); }
    }
    @media (max-width: 999px) {
      .side-banners { display: none !important; }
      .mobile-banners { display: flex !important; }
      .projects-list { grid-template-columns: 1fr; align-items: center; display: flex; flex-direction: column; }
      .projects-list-wrapper {
        margin-left: 0 !important;
        margin-right: 0 !important;
      }
      .projects-section {
        display: flex;
        flex-direction: column;
        align-items: center;
      }
      .project-card {
        margin-left: auto;
        margin-right: auto;
      }
    }
    .coming-soon-message {
      text-align: center;
      font-size: 2rem;
      color: #ffd32a;
      font-family: 'Orbitron', 'Share Tech Mono', monospace;
      margin: 2.5rem 0;
      font-weight: bold;
      text-shadow: 0 0 8px #3c40c6, 0 0 4px #f53b57;
    }
  </style>
</head>
<body>
  <%- include('navbar-ticker.ejs', { lang }) %>
  <div class="container">
    <!-- Cyberpunk Smoke Effect Canvas -->
    <canvas id="cyberpunk-smoke" width="600" height="400" style="position: fixed; right: 0; bottom: 0; pointer-events: none; z-index: 10;"></canvas>
    <section class="hero">
      <h1><%= t.heading %></h1>
      <div class="hero-underline"></div>
      <div class="description"><%= t.description %></div>
      <div class="actions">
        <button class="btn btn-primary" id="our-work-btn">🛠️ <%= t.getStarted %></button>
        <a class="btn btn-secondary btn-linklike" href="mailto:geanify@gmail.com" role="button" tabindex="0">✉️ <%= t.learnMore %></a>
      </div>
    </section>
    <section class="projects-section">
      <div class="projects-title"><%= t.projectsHeading %></div>
      <div class="projects-list-wrapper" style="display: flex; flex-direction: row; justify-content: center; align-items: flex-start; width: 100%;">
        <!-- Desktop left banner -->
        <div class="side-banners" style="display: none; flex-direction: column; gap: 2rem; margin-right: 2rem;">
          <%- include('banner-ad.ejs', { type: 'overconsumption', t: t }) %>
        </div>
        <div class="projects-list" style="flex: 1;">
          <% if (t.projects.length === 0) { %>
            <div class="coming-soon-message"><%= t.comingSoon %></div>
          <% } else { %>
            <% t.projects.forEach(function(project, idx) { %>
              <% if (idx === 1) { %>
                <!-- Mobile banners after first project -->
                <div class="mobile-banners" style="display: none; flex-direction: column; gap: 1.5rem; margin: 1.5rem 0;">
                  <%- include('banner-ad.ejs', { type: 'overconsumption', t: t }) %>
                  <%- include('banner-ad.ejs', { type: 'subscriptions', t: t }) %>
                </div>
              <% } %>
              <%- include('project-card.ejs', { project }) %>
            <% }); %>
          <% } %>
        </div>
        <!-- Desktop right banner -->
        <div class="side-banners" style="display: none; flex-direction: column; gap: 2rem; margin-left: 2rem;">
          <%- include('banner-ad.ejs', { type: 'subscriptions', t: t }) %>
        </div>
      </div>
    </section>
  </div>
  <footer>
    &copy; <%= new Date().getFullYear() %> <%= t.footer %>
  </footer>
  <script>
    // Smooth scroll and highlight for Our Work button
    document.addEventListener('DOMContentLoaded', function() {
      var btn = document.getElementById('our-work-btn');
      var section = document.querySelector('.projects-section');
      if (btn && section) {
        btn.addEventListener('click', function(e) {
          e.preventDefault();
          section.scrollIntoView({ behavior: 'smooth', block: 'center' });
          section.classList.add('highlight-section');
          setTimeout(function() {
            section.classList.remove('highlight-section');
          }, 1200);
        });
      }
    });
    // Neon effect on logo tap for mobile
    document.addEventListener('DOMContentLoaded', function() {
      var logo = document.querySelector('.logo');
      if (logo) {
        var addNeon = function() {
          logo.classList.add('logo-tap-neon');
          setTimeout(function() {
            logo.classList.remove('logo-tap-neon');
          }, 400);
        };
        logo.addEventListener('touchstart', addNeon);
      }

      // Neon effect on project card tap/click/hover
      var cards = document.querySelectorAll('.project-card');
      cards.forEach(function(card) {
        var animate = function() {
          card.classList.add('project-card-flashy-neon');
          setTimeout(function() {
            card.classList.remove('project-card-flashy-neon');
          }, 400);
        };
        card.addEventListener('touchstart', animate);
        card.addEventListener('mousedown', animate);
        card.addEventListener('mouseenter', animate);
      });
    });
  </script>
  <script src="/smoke-effect.js"></script>
</body>
</html> 