<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= t.title %></title>
  <style>
    :root {
      --neutral: #808e9b;
      --neutral-highlight: #d2dae2;
      --neutral-text: #ffffff;
      --primary: #f53b57;
      --primary-highlight: #ef5777;
      --primary-text: #dfbdc4;
      --secondary: #3c40c6;
      --secondary-highlight: #575fcf;
      --secondary-text: #bae2e2;
      --danger: #ff3f34;
      --danger-highlight: #ff5e57;
      --danger-text: #dfaca9;
      --warning: #ffa801;
      --warning-highlight: #ffc048;
      --warning-text: rgb(238, 228, 208);
      --success: #05c46b;
      --success-highlight: #0be881;
      --success-text: #98e4c0;
      --background-dark: #1e272e;
      --background-dark-highlight: #485460;
      --overlay-background: rgba(72, 84, 96, 0.5);
      --accent: #ffd32a;
      --accent-highlight: #ffdd59;
      --accent-text: #ffffff;
      --small-font-size: 14px;
      --medium-font-size: 16px;
      --large-font-size: 18px;
    }
    html, body {
      height: 100%;
      margin: 0;
      padding: 0;
      font-family: 'Segoe UI', 'Roboto', 'Arial', sans-serif;
      background: linear-gradient(135deg, var(--background-dark) 65%, rgba(30,39,46,0.96) 100%);
      color: var(--neutral-text);
      min-height: 100vh;
      max-width: 100vw;
      overflow-x: hidden;
    }
    body {
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }
    .lang-switcher {
      position: fixed;
      top: 1rem;
      right: 1rem;
      z-index: 100;
      display: flex;
      gap: 0.5rem;
      background: var(--background-dark-highlight);
      padding: 0.3rem 0.7rem;
      border-radius: 8px;
      box-shadow: 0 2px 8px var(--overlay-background);
    }
    .lang-switcher a {
      color: var(--neutral-highlight);
      background: var(--background-dark-highlight);
      padding: 0.25rem 0.75rem;
      border-radius: 6px;
      text-decoration: none;
      font-weight: 600;
      font-size: var(--medium-font-size);
      transition: background 0.2s, color 0.2s;
    }
    .lang-switcher a.active, .lang-switcher a:hover {
      background: var(--primary);
      color: var(--primary-text);
    }
    .container {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      padding: 2.5rem 1rem 1rem 1rem;
      max-width: 1100px;
      margin: 0 auto;
      width: 100%;
      box-sizing: border-box;
    }
    .logo-link {
      display: flex;
      align-items: center;
      margin-right: 1.5rem;
      margin-bottom: 0;
      position: static;
    }
    .logo {
      width: 100px;
      height: 100px;
      border-radius: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    .logo img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      display: block;
    }
    h1 {
      font-size: 2.2rem;
      color: var(--primary);
      margin: 0 0 0.5rem 0;
      letter-spacing: 1px;
      font-weight: 700;
      text-shadow: 0 2px 8px var(--overlay-background);
      text-align: center;
    }
    .description {
      font-size: 1.15rem;
      color: var(--neutral-highlight);
      margin: 0 0 2rem 0;
      max-width: 700px;
      text-align: center;
    }
    .actions {
      display: flex;
      gap: 1rem;
      margin-bottom: 2.5rem;
      justify-content: center;
      flex-wrap: wrap;
    }
    .btn, .btn-linklike {
      min-width: 200px;
      width: 200px !important;
      box-sizing: border-box;
      padding: 0.85rem 2.2rem;
      font-size: var(--medium-font-size);
      border: none;
      border-radius: 8px;
      cursor: pointer;
      font-weight: 600;
      transition: background 0.2s, color 0.2s, box-shadow 0.2s;
      box-shadow: 0 2px 8px var(--overlay-background);
      margin-bottom: 0.5rem;
    }
    .btn-primary {
      background: var(--primary);
      color: var(--primary-text);
    }
    .btn-primary:hover {
      background: var(--primary-highlight);
      color: var(--accent-text);
    }
    .btn-secondary {
      background: var(--secondary);
      color: var(--secondary-text);
    }
    .btn-secondary:hover {
      background: var(--secondary-highlight);
      color: var(--accent-text);
    }
    .projects-section {
      width: 100%;
      margin-top: 2.5rem;
      margin-bottom: 2rem;
    }
    .projects-title {
      font-size: 1.7rem;
      color: var(--accent);
      margin-bottom: 1.5rem;
      text-align: center;
      font-weight: 700;
      letter-spacing: 1px;
    }
    .projects-list {
      display: flex;
      flex-wrap: wrap;
      gap: 2rem;
      justify-content: center;
      max-width: 100vw;
      box-sizing: border-box;
    }
    .project-card {
      background: var(--background-dark-highlight);
      border-radius: 18px;
      box-shadow: 0 2px 12px var(--overlay-background);
      width: 320px;
      max-width: calc(100vw - 2.5rem);
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 1.5rem 1rem 1.2rem 1rem;
      transition: transform 0.15s, box-shadow 0.15s;
      border: 2px solid transparent;
      min-width: 0;
      box-sizing: border-box;
    }
    .project-card:hover {
      transform: translateY(-6px) scale(1.03);
      box-shadow: 0 6px 24px var(--overlay-background);
      border-color: var(--primary);
    }
    .project-image {
      width: 90px;
      height: 90px;
      border-radius: 12px;
      background: var(--neutral-highlight);
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      box-shadow: 0 2px 8px var(--overlay-background);
    }
    .project-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .project-title {
      font-size: 1.2rem;
      color: var(--primary);
      font-weight: 600;
      margin-bottom: 0.5rem;
      text-align: center;
    }
    .project-description {
      color: var(--neutral-highlight);
      font-size: 1rem;
      text-align: center;
      margin-bottom: 0.5rem;
    }
    .project-card-link {
      display: block;
      text-decoration: none !important;
      color: inherit !important;
      cursor: pointer;
    }
    .project-card-link:visited,
    .project-card-link:active,
    .project-card-link:focus {
      color: inherit !important;
      text-decoration: none !important;
      outline: none;
    }
    .project-card-link .project-card,
    .project-card-link .project-card:hover {
      box-shadow: 0 2px 12px var(--overlay-background);
      border-color: transparent;
      background: var(--background-dark-highlight);
      transition: none;
    }
    footer {
      text-align: center;
      padding: 1.5rem 0 1rem 0;
      background: var(--background-dark-highlight);
      color: var(--neutral);
      font-size: var(--small-font-size);
      letter-spacing: 0.5px;
      box-shadow: 0 -2px 12px var(--background-dark-highlight);
      margin-top: 3rem;
      border-top: 2px solid transparent;
      background-clip: padding-box;
      position: relative;
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
    }
    footer::before {
      content: "";
      position: absolute;
      left: 0; right: 0; top: 0; height: 2px;
      background: linear-gradient(90deg, var(--background-dark), var(--primary), var(--accent), var(--background-dark-highlight));
      opacity: 0.25;
      z-index: 1;
      pointer-events: none;
    }
    @media (max-width: 900px) {
      .projects-list {
        flex-direction: column;
        align-items: center;
        max-width: 100vw;
      }
      .project-card {
        width: 100%;
        max-width: calc(100vw - 2.5rem);
        box-sizing: border-box;
      }
    }
    @media (max-width: 600px) {
      h1 {
        font-size: 1.3rem;
      }
      .container {
        padding: 1rem 0.5rem 0.5rem 0.5rem;
        max-width: 100vw;
      }
      .logo {
        width: 70px;
        height: 70px;
      }
      .projects-title {
        font-size: 1.2rem;
      }
      .actions {
        flex-direction: column;
        gap: 0.5rem;
        align-items: stretch;
      }
      .btn, .btn-linklike {
        width: 100%;
        min-width: 0;
        font-size: 1rem;
        padding: 0.9rem 0.5rem;
      }
      .lang-switcher {
        top: 0.5rem;
        right: 0.5rem;
        padding: 0.2rem 0.4rem;
        font-size: 0.95rem;
      }
      .project-card {
        width: 100%;
        max-width: calc(100vw - 1.2rem);
        margin-left: auto;
        margin-right: auto;
      }
      .project-image {
        width: 60px;
        height: 60px;
      }
      .navbar {
        max-width: 100vw;
      }
      .navbar-content {
        max-width: 100vw;
      }
      .projects-list {
        max-width: 100vw;
      }
      .project-card {
        max-width: calc(100vw - 1.2rem);
      }
    }
    .navbar {
      width: 100vw;
      max-width: 100vw;
      left: 0;
      right: 0;
      top: 0;
      background: rgba(30, 39, 46, 0.92);
      box-shadow: 0 2px 16px 0 rgba(72, 84, 96, 0.10);
      min-height: 120px;
      display: flex;
      align-items: center;
      justify-content: center;
      position: sticky;
      z-index: 100;
      margin-bottom: 2rem;
      backdrop-filter: blur(8px);
      border-bottom: 2px solid var(--background-dark-highlight);
      transition: background 0.3s;
    }
    .navbar-content {
      min-height: 120px;
      align-items: center;
      width: 100%;
      max-width: 1100px;
      box-sizing: border-box;
      display: flex;
      gap: 0.5rem;
      justify-content: space-between;
      padding: 0.2rem 1.5rem;
    }
    .logo-link {
      display: flex;
      align-items: center;
      margin-right: 1.5rem;
      margin-bottom: 0;
      position: static;
      transition: transform 0.15s;
    }
    .logo-link:hover .logo {
      box-shadow: 0 6px 32px var(--primary-highlight);
      transform: scale(1.05) rotate(-2deg);
      background: var(--primary-highlight);
    }
    .logo {
      width: 100px;
      height: 100px;
      border-radius: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      transition: box-shadow 0.2s, background 0.2s, transform 0.2s;
    }
    .logo img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      display: block;
    }
    .lang-switcher {
      display: flex;
      gap: 0.5rem;
      background: none;
      box-shadow: none;
      padding: 0;
      border-radius: 0;
      position: static;
    }
    .lang-switcher a {
      color: var(--accent-text);
      background: var(--accent);
      padding: 0.4rem 1.1rem;
      border-radius: 8px;
      text-decoration: none;
      font-weight: 700;
      font-size: var(--medium-font-size);
      transition: background 0.2s, color 0.2s, box-shadow 0.2s;
      box-shadow: 0 2px 8px var(--overlay-background);
      border: 2px solid transparent;
      letter-spacing: 1px;
    }
    .lang-switcher a.active, .lang-switcher a:hover {
      background: var(--primary);
      color: var(--primary-text);
      border-color: var(--primary-highlight);
    }
    .container {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      padding: 2.5rem 1rem 1rem 1rem;
      max-width: 1100px;
      margin: 0 auto;
      width: 100%;
      box-sizing: border-box;
    }
    .hero {
      width: 100%;
      margin-bottom: 2.5rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      position: relative;
      z-index: 1;
    }
    h1 {
      font-size: 2.5rem;
      color: var(--primary);
      margin: 0 0 0.7rem 0;
      letter-spacing: 1px;
      font-weight: 800;
      text-shadow: 0 2px 12px var(--overlay-background);
      text-align: center;
      position: relative;
      z-index: 2;
    }
    .hero-underline {
      width: 80px;
      height: 6px;
      background: linear-gradient(90deg, var(--accent), var(--primary-highlight));
      border-radius: 3px;
      margin: 0.5rem auto 1.2rem auto;
      box-shadow: 0 2px 8px var(--primary-highlight);
      opacity: 0.85;
    }
    .description {
      font-size: 1.18rem;
      color: var(--neutral-highlight);
      margin: 0 0 2.2rem 0;
      max-width: 700px;
      text-align: center;
      line-height: 1.6;
      font-weight: 500;
    }
    .actions {
      display: flex;
      gap: 1.2rem;
      margin-bottom: 2.8rem;
      justify-content: center;
      flex-wrap: wrap;
    }
    .btn {
      padding: 0.95rem 2.3rem;
      font-size: 1.1rem;
      border: none;
      border-radius: 10px;
      cursor: pointer;
      font-weight: 700;
      transition: background 0.18s, color 0.18s, box-shadow 0.18s, transform 0.18s;
      box-shadow: 0 2px 12px var(--overlay-background);
      min-width: 170px;
      margin-bottom: 0.5rem;
      background: var(--primary);
      color: var(--primary-text);
      letter-spacing: 0.5px;
    }
    .btn-primary {
      background: var(--primary);
      color: var(--primary-text);
    }
    .btn-primary:hover, .btn-primary:focus {
      background: var(--primary-highlight);
      color: var(--accent-text);
      transform: translateY(-2px) scale(1.04);
      box-shadow: 0 4px 18px var(--primary-highlight);
    }
    .btn-secondary {
      background: var(--secondary);
      color: var(--secondary-text);
    }
    .btn-secondary:hover, .btn-secondary:focus {
      background: var(--secondary-highlight);
      color: var(--accent-text);
      transform: translateY(-2px) scale(1.04);
      box-shadow: 0 4px 18px var(--secondary-highlight);
    }
    .projects-section {
      width: 100%;
      margin-top: 2.5rem;
      margin-bottom: 2rem;
      position: relative;
      z-index: 1;
    }
    .projects-title {
      font-size: 1.7rem;
      color: var(--accent);
      margin-bottom: 1.5rem;
      text-align: center;
      font-weight: 800;
      letter-spacing: 1px;
      text-shadow: 0 2px 8px var(--overlay-background);
    }
    .projects-list {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(290px, 1fr));
      gap: 2rem;
      justify-content: center;
      max-width: 100vw;
      box-sizing: border-box;
    }
    .project-card-link {
      display: block;
      text-decoration: none !important;
      color: inherit !important;
      cursor: pointer;
    }
    .project-card-link:visited,
    .project-card-link:active,
    .project-card-link:focus {
      color: inherit !important;
      text-decoration: none !important;
      outline: none;
    }
    .project-card-link .project-card,
    .project-card-link .project-card:hover {
      box-shadow: 0 2px 12px var(--overlay-background);
      border-color: transparent;
      background: var(--background-dark-highlight);
      transition: none;
    }
    .project-card {
      width: 100%;
      max-width: calc(100vw - 2.5rem);
      box-sizing: border-box;
      background: var(--background-dark-highlight);
      border-radius: 18px;
      box-shadow: 0 2px 12px var(--overlay-background);
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 1.5rem 1rem 1.2rem 1rem;
      transition: transform 0.15s, box-shadow 0.15s;
      border: 2px solid transparent;
      min-width: 0;
      position: relative;
      overflow: hidden;
    }
    .project-card:hover {
      transform: translateY(-6px) scale(1.03);
      box-shadow: 0 6px 24px var(--primary-highlight);
      border-color: var(--primary);
      z-index: 2;
    }
    .project-image {
      width: 90px;
      height: 90px;
      border-radius: 12px;
      background: var(--neutral-highlight);
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      box-shadow: 0 2px 8px var(--overlay-background);
    }
    .project-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      background: var(--neutral-highlight);
    }
    .project-title {
      font-size: 1.2rem;
      color: var(--primary);
      font-weight: 700;
      margin-bottom: 0.5rem;
      text-align: center;
      letter-spacing: 0.5px;
    }
    .project-description {
      color: var(--neutral-highlight);
      font-size: 1rem;
      text-align: center;
      margin-bottom: 0.5rem;
      font-weight: 500;
    }
    .view-project-btn {
      margin-top: 0.7rem;
      padding: 0.5rem 1.2rem;
      background: var(--accent);
      color: var(--accent-text);
      border: none;
      border-radius: 7px;
      font-weight: 700;
      font-size: 1rem;
      cursor: pointer;
      box-shadow: 0 1px 6px var(--overlay-background);
      transition: background 0.18s, color 0.18s, box-shadow 0.18s;
      letter-spacing: 0.5px;
    }
    .view-project-btn:hover, .view-project-btn:focus {
      background: var(--primary);
      color: var(--primary-text);
      box-shadow: 0 2px 12px var(--primary-highlight);
    }
    footer {
      text-align: center;
      padding: 1.5rem 0 1rem 0;
      background: var(--background-dark-highlight);
      color: var(--neutral);
      font-size: var(--small-font-size);
      letter-spacing: 0.5px;
      box-shadow: 0 -2px 12px var(--background-dark-highlight);
      margin-top: 3rem;
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
    }
    @media (max-width: 900px) {
      .projects-list {
         flex-direction: column;
         align-items: center;
         max-width: 100vw;
      }
      .project-card {
         width: 100%;
         max-width: calc(100vw - 2.5rem);
         box-sizing: border-box;
      }
    }
    @media (max-width: 600px) {
      .container {
         padding: 1rem 0.5rem 0.5rem 0.5rem;
         max-width: 100vw;
      }
      .hero-underline {
         width: 50px;
         height: 4px;
      }
      .logo {
         width: 70px;
         height: 70px;
      }
      .projects-title {
         font-size: 1.2rem;
      }
      .navbar {
         max-width: 100vw;
         min-height: 80px;
      }
      .navbar-content {
         max-width: 100vw;
         min-height: 80px;
         padding: 0.2rem 0.5rem;
      }
      .projects-list {
         max-width: 100vw;
         grid-template-columns: 1fr;
      }
      .project-card {
         width: 100%;
         max-width: calc(100vw - 1.2rem);
         margin-left: auto;
         margin-right: auto;
      }
    }
    .highlight-section {
      box-shadow: 0 0 0 4px var(--accent), 0 2px 24px var(--primary-highlight);
      transition: box-shadow 0.3s;
      z-index: 10;
      border-radius: 18px;
    }
    .btn-linklike {
      display: inline-block;
      text-align: center;
      text-decoration: none !important;
      appearance: none;
      -webkit-appearance: none;
      -moz-appearance: none;
      border: none;
      outline: none;
      background: var(--secondary);
      color: var(--secondary-text);
      font: inherit;
      cursor: pointer;
      padding: 0.95rem 2.3rem;
      font-size: 1.1rem;
      border-radius: 10px;
      font-weight: 700;
      box-shadow: 0 2px 12px var(--overlay-background);
      min-width: 170px;
      margin-bottom: 0.5rem;
      letter-spacing: 0.5px;
      transition: background 0.18s, color 0.18s, box-shadow 0.18s, transform 0.18s;
    }
    .btn-linklike:hover, .btn-linklike:focus {
      background: var(--secondary-highlight);
      color: var(--accent-text);
      transform: translateY(-2px) scale(1.04);
      box-shadow: 0 4px 18px var(--secondary-highlight);
      text-decoration: none !important;
    }
  </style>
</head>
<body>
  <nav class="navbar">
    <div class="navbar-content">
      <a href="/" class="logo-link">
        <div class="logo">
          <img src="/logo.png" alt="Web Herald Logo">
        </div>
      </a>
      <div class="navbar-spacer"></div>
      <div class="lang-switcher">
        <a href="?lang=en" class="<%= lang === 'en' ? 'active' : '' %>">🇬🇧 EN</a>
        <a href="?lang=ro" class="<%= lang === 'ro' ? 'active' : '' %>">🇷🇴 RO</a>
      </div>
    </div>
  </nav>
  <div class="container">
    <section class="hero">
      <h1><%= t.heading %></h1>
      <div class="hero-underline"></div>
      <div class="description"><%= t.description %></div>
      <div class="actions">
        <button class="btn btn-primary" id="our-work-btn">🛠️ Our Work</button>
        <a class="btn btn-secondary btn-linklike" href="mailto:geanify@gmail.com" role="button" tabindex="0">✉️ Contact Us</a>
      </div>
    </section>
    <section class="projects-section">
      <div class="projects-title"><%= t.projectsHeading %></div>
      <div class="projects-list">
        <% t.projects.forEach(function(project) { %>
          <%- include('project-card.ejs', { project }) %>
        <% }); %>
      </div>
    </section>
  </div>
  <footer>
    &copy; <%= new Date().getFullYear() %> <%= t.footer %>
  </footer>
  <script>
    // Smooth scroll and highlight for Our Work button
    document.addEventListener('DOMContentLoaded', function() {
      var btn = document.getElementById('our-work-btn');
      var section = document.querySelector('.projects-section');
      if (btn && section) {
        btn.addEventListener('click', function(e) {
          e.preventDefault();
          section.scrollIntoView({ behavior: 'smooth', block: 'center' });
          section.classList.add('highlight-section');
          setTimeout(function() {
            section.classList.remove('highlight-section');
          }, 1200);
        });
      }
    });
  </script>
</body>
</html> 