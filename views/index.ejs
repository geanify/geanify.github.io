<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= t.title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
  <link rel="icon" type="image/png" href="/logo.png">
  <style>
    :root {
      --neutral: #808e9b;
      --neutral-highlight: #d2dae2;
      --neutral-text: #ffffff;
      --primary: #f53b57;
      --primary-highlight: #ef5777;
      --primary-text: #dfbdc4;
      --secondary: #3c40c6;
      --secondary-highlight: #575fcf;
      --secondary-text: #bae2e2;
      --danger: #ff3f34;
      --danger-highlight: #ff5e57;
      --danger-text: #dfaca9;
      --warning: #ffa801;
      --warning-highlight: #ffc048;
      --warning-text: rgb(238, 228, 208);
      --success: #05c46b;
      --success-highlight: #0be881;
      --success-text: #98e4c0;
      --background-dark: #1e272e;
      --background-dark-highlight: #485460;
      --overlay-background: rgba(72, 84, 96, 0.5);
      --accent: #ffd32a;
      --accent-highlight: #ffdd59;
      --accent-text: #ffffff;
      --small-font-size: 14px;
      --medium-font-size: 16px;
      --large-font-size: 18px;
    }
    html, body {
      height: 100%;
      margin: 0;
      padding: 0;
      font-family: 'Share Tech Mono', 'Orbitron', 'Segoe UI', 'Roboto', 'Arial', sans-serif;
      background: linear-gradient(120deg, #0f2027 0%, #2c5364 60%, #1a0033 100%);
      color: var(--neutral-text);
      min-height: 100vh;
      max-width: 100vw;
      overflow-x: hidden;
      letter-spacing: 0.5px;
    }
    body {
      display: flex;
      flex-direction: column;
      min-height: 100vh;
      position: relative;
    }
    .lang-switcher {
      position: fixed;
      top: 1rem;
      right: 1rem;
      z-index: 100;
      display: flex;
      gap: 0.5rem;
      background: var(--background-dark-highlight);
      padding: 0.3rem 0.7rem;
      border-radius: 8px;
      box-shadow: 0 2px 8px var(--overlay-background);
    }
    .lang-switcher a {
      color: var(--neutral-highlight);
      background: var(--background-dark-highlight);
      padding: 0.25rem 0.75rem;
      border-radius: 6px;
      text-decoration: none;
      font-weight: 600;
      font-size: var(--medium-font-size);
      transition: background 0.2s, color 0.2s;
    }
    .lang-switcher a.active, .lang-switcher a:hover {
      background: var(--primary);
      color: var(--primary-text);
    }
    .container {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      padding: 2.5rem 1rem 1rem 1rem;
      max-width: 1100px;
      margin: 0 auto;
      width: 100%;
      box-sizing: border-box;
    }
    .logo-link {
      display: flex;
      align-items: center;
      margin-right: 1.5rem;
      margin-bottom: 0;
      position: static;
      transition: transform 0.15s, filter 0.2s;
    }
    .logo {
      width: 100px;
      height: 100px;
      border-radius: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      background: var(--neon-yellow);
      box-shadow: 0 0 24px 4px var(--neon-blue), 0 0 8px 2px var(--neon-pink);
      transition: box-shadow 0.2s, background 0.2s, transform 0.2s;
    }
    .logo img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      display: block;
    }
    h1 {
      font-size: 2.7rem;
      color: #ffd32a;
      margin: 0 0 0.7rem 0;
      letter-spacing: 2px;
      font-weight: 900;
      text-shadow: 0 0 16px #f53b57, 0 0 32px #3c40c6, 0 2px 12px #ffd32a;
      text-align: center;
      position: relative;
      z-index: 2;
      font-family: 'Orbitron', 'Share Tech Mono', monospace;
    }
    .description {
      font-size: 1.18rem;
      color: #bae2e2;
      margin: 0 0 2.2rem 0;
      max-width: 700px;
      text-align: center;
      line-height: 1.6;
      font-weight: 500;
      text-shadow: 0 0 8px #3c40c6, 0 0 4px #f53b57;
    }
    .actions {
      display: flex;
      gap: 1.2rem;
      margin-bottom: 2.8rem;
      justify-content: center;
      flex-wrap: wrap;
    }
    .btn, .btn-linklike {
      min-width: 200px;
      width: 200px !important;
      box-sizing: border-box;
      padding: 0.95rem 2.3rem;
      font-size: 1.1rem;
      border: none;
      border-radius: 10px;
      cursor: pointer;
      font-weight: 900;
      transition: background 0.18s, color 0.18s, box-shadow 0.18s, transform 0.18s, filter 0.18s;
      box-shadow: 0 0 16px 2px #f53b57, 0 0 8px 2px #3c40c6;
      margin-bottom: 0.5rem;
      background: linear-gradient(90deg, #f53b57 0%, #3c40c6 100%);
      color: #fff;
      letter-spacing: 1.2px;
      text-shadow: 0 0 8px #ffd32a, 0 0 4px #3c40c6;
      font-family: 'Orbitron', 'Share Tech Mono', monospace;
    }
    .btn-primary {
      background: linear-gradient(90deg, #f53b57 0%, #ffd32a 100%);
      color: #1a0033;
      border: 2px solid #ffd32a;
    }
    .btn-primary:hover, .btn-primary:focus {
      background: linear-gradient(90deg, #ffd32a 0%, #f53b57 100%);
      color: #fff;
      border-color: #f53b57;
      filter: brightness(1.2) drop-shadow(0 0 8px #ffd32a);
      transform: translateY(-2px) scale(1.04);
      box-shadow: 0 0 32px 8px #f53b57, 0 0 16px 4px #3c40c6;
    }
    .btn-secondary {
      background: linear-gradient(90deg, #3c40c6 0%, #05c46b 100%);
      color: #fff;
      border: 2px solid #05c46b;
    }
    .btn-secondary:hover, .btn-secondary:focus, .btn-linklike:hover, .btn-linklike:focus {
      background: linear-gradient(90deg, #05c46b 0%, #3c40c6 100%);
      color: #ffd32a;
      border-color: #ffd32a;
      filter: brightness(1.2) drop-shadow(0 0 8px #05c46b);
      transform: translateY(-2px) scale(1.04);
      box-shadow: 0 0 32px 8px #3c40c6, 0 0 16px 4px #05c46b;
      text-decoration: none !important;
    }
    .projects-section {
      width: 100%;
      margin-top: 2.5rem;
      margin-bottom: 2rem;
      background: var(--neon-yellow);
      border-radius: 18px;
      box-shadow: 0 0 32px 8px var(--neon-blue), 0 0 16px 4px var(--neon-pink);
      position: relative;
      z-index: 1;
    }
    .projects-title {
      font-size: 1.7rem;
      color: #ffd32a;
      margin-bottom: 1.5rem;
      text-align: center;
      font-weight: 800;
      letter-spacing: 1px;
      text-shadow: 0 2px 8px var(--overlay-background);
    }
    .projects-list {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(290px, 1fr));
      gap: 2rem;
      justify-content: center;
      max-width: 100vw;
      box-sizing: border-box;
    }
    .project-card {
      width: 100%;
      max-width: calc(100vw - 2.5rem);
      box-sizing: border-box;
      background: #1a0033;
      border-radius: 24px;
      box-shadow: 0 0 24px 4px var(--neon-blue), 0 0 8px 2px var(--neon-pink);
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 1.5rem 1rem 1.2rem 1rem;
      border: 3px solid #222b3a;
      min-width: 0;
      position: relative;
      overflow: hidden;
      transition: box-shadow 0.2s, background 0.2s, border-color 0.2s, filter 0.2s, transform 0.2s;
    }
    .project-card:hover, .project-card-flashy-neon {
      background: #1a0033;
      box-shadow:
        0 0 48px 12px #00f0ff,
        0 0 32px 8px #f53b57,
        0 0 24px 8px #ffd32a,
        0 0 16px 8px #05c46b;
      border-color: #00f0ff;
      filter: brightness(1.3) saturate(1.5) drop-shadow(0 0 12px #ffd32a);
      transform: scale(1.08) rotate(-2deg);
      animation: project-card-flash 0.4s linear;
      z-index: 2;
    }
    @keyframes project-card-flash {
      0% { box-shadow: 0 0 0 0 #00f0ff, 0 0 0 0 #f53b57, 0 0 0 0 #ffd32a, 0 0 0 0 #05c46b; }
      40% { box-shadow: 0 0 64px 24px #00f0ff, 0 0 48px 16px #f53b57, 0 0 32px 12px #ffd32a, 0 0 24px 8px #05c46b; }
      100% { box-shadow: 0 0 48px 12px #00f0ff, 0 0 32px 8px #f53b57, 0 0 24px 8px #ffd32a, 0 0 16px 8px #05c46b; }
    }
    .project-card::after {
      content: '';
      position: absolute;
      top: -8px; left: -8px; right: -8px; bottom: -8px;
      border-radius: 28px;
      pointer-events: none;
      z-index: 10;
      border: 3px solid #00f0ff;
      box-shadow: 0 0 48px 16px #00f0ff, 0 0 24px 8px #3c40c6;
      opacity: 0;
      transition: opacity 0.2s;
    }
    .project-card:hover::after, .project-card-flashy-neon::after {
      opacity: 1;
      animation: project-card-border-flash 0.4s linear;
    }
    @keyframes project-card-border-flash {
      0% { opacity: 0; }
      40% { opacity: 1; }
      100% { opacity: 1; }
    }
    .project-image {
      width: 90px;
      height: 90px;
      border-radius: 12px;
      background: #222b3a;
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      box-shadow: 0 2px 8px var(--overlay-background);
    }
    .project-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      background: #222b3a;
    }
    .project-title {
      font-size: 1.2rem;
      color: #ffd32a;
      font-weight: 700;
      margin-bottom: 0.5rem;
      text-align: center;
      letter-spacing: 0.5px;
      font-family: 'Orbitron', 'Share Tech Mono', monospace;
      text-shadow: 0 0 8px #f53b57, 0 0 4px #3c40c6;
    }
    .project-description {
      color: #bae2e2;
      font-size: 1rem;
      text-align: center;
      margin-bottom: 0.5rem;
      font-weight: 500;
      text-shadow: 0 0 8px #3c40c6, 0 0 4px #f53b57;
    }
    .project-card-link {
      display: block;
      text-decoration: none !important;
      color: inherit !important;
      cursor: pointer;
    }
    .project-card-link:visited,
    .project-card-link:active,
    .project-card-link:focus {
      color: inherit !important;
      text-decoration: none !important;
      outline: none;
    }
    .project-card-link .project-card,
    .project-card-link .project-card:hover {
      box-shadow: 0 0 24px 4px #3c40c6, 0 0 8px 2px #f53b57;
      border-color: #ffd32a;
      background: #1a0033;
      transition: box-shadow 0.2s, border-color 0.2s, background 0.2s;
    }
    footer {
      text-align: center;
      padding: 1.5rem 0 1rem 0;
      background: var(--background-dark-highlight);
      color: var(--neutral);
      font-size: var(--small-font-size);
      letter-spacing: 0.5px;
      box-shadow: 0 -2px 12px var(--background-dark-highlight);
      margin-top: 3rem;
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
    }
    @media (max-width: 900px) {
      .projects-list {
         flex-direction: column;
         align-items: center;
         max-width: 100vw;
      }
      .project-card {
         width: 100%;
         max-width: calc(100vw - 2.5rem);
         box-sizing: border-box;
      }
    }
    @media (max-width: 600px) {
      h1 {
        font-size: 1.3rem;
      }
      .container {
        padding: 1rem 0.5rem 0.5rem 0.5rem;
        max-width: 100vw;
      }
      .logo {
        width: 70px;
        height: 70px;
      }
      .projects-title {
        font-size: 1.2rem;
      }
      .actions {
        flex-direction: column;
        gap: 0.5rem;
        align-items: stretch;
      }
      .btn, .btn-linklike {
        width: 100%;
        min-width: 0;
        font-size: 1rem;
        padding: 0.9rem 0.5rem;
      }
      .lang-switcher {
        top: 0.5rem;
        right: 0.5rem;
        padding: 0.2rem 0.4rem;
        font-size: 0.95rem;
      }
      .project-card {
        width: 100%;
        max-width: calc(100vw - 1.2rem);
        margin-left: auto;
        margin-right: auto;
      }
      .project-image {
        width: 60px;
        height: 60px;
      }
      .navbar {
        max-width: 100vw;
      }
      .navbar-content {
        max-width: 100vw;
      }
      .projects-list {
        max-width: 100vw;
      }
      .project-card {
        max-width: calc(100vw - 1.2rem);
      }
    }
    .navbar {
      width: 100vw;
      max-width: 100vw;
      left: 0;
      right: 0;
      top: 0;
      background: rgba(20, 10, 40, 0.92);
      box-shadow: 0 2px 32px 0 #f53b57cc, 0 0px 0px 2px #3c40c6cc;
      min-height: 120px;
      display: flex;
      align-items: center;
      justify-content: center;
      position: sticky;
      z-index: 100;
      margin-bottom: 2rem;
      backdrop-filter: blur(8px);
      border-bottom: 2px solid #f53b57;
      transition: background 0.3s;
    }
    .navbar-content {
      min-height: 120px;
      align-items: center;
      width: 100%;
      max-width: 1100px;
      box-sizing: border-box;
      display: flex;
      gap: 0.5rem;
      justify-content: space-between;
      padding: 0.2rem 1.5rem;
      font-family: 'Orbitron', 'Share Tech Mono', monospace;
    }
    .logo-link:hover .logo {
      box-shadow: 0 0 32px 8px #f53b57, 0 0 16px 4px #3c40c6;
      filter: brightness(1.3) saturate(1.5) drop-shadow(0 0 12px #ffd32a);
      transform: scale(1.08) rotate(-2deg);
      background: #1a0033;
    }
    .hero {
      width: 100%;
      margin-bottom: 2.5rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      position: relative;
      z-index: 1;
      font-family: 'Orbitron', 'Share Tech Mono', monospace;
    }
    .hero-underline {
      width: 120px;
      height: 8px;
      background: linear-gradient(90deg, #f53b57, #ffd32a, #3c40c6);
      border-radius: 4px;
      margin: 0.5rem auto 1.2rem auto;
      box-shadow: 0 0 16px #f53b57, 0 0 16px #3c40c6;
      opacity: 0.95;
      animation: neon-underline 2.5s infinite alternate;
    }
    @keyframes neon-underline {
      0% { filter: brightness(1.2) drop-shadow(0 0 8px #ffd32a); }
      100% { filter: brightness(2.2) drop-shadow(0 0 24px #3c40c6); }
    }
    .view-project-btn {
      margin-top: 0.7rem;
      padding: 0.5rem 1.2rem;
      background: var(--accent);
      color: var(--accent-text);
      border: none;
      border-radius: 7px;
      font-weight: 700;
      font-size: 1rem;
      cursor: pointer;
      box-shadow: 0 1px 6px var(--overlay-background);
      transition: background 0.18s, color 0.18s, box-shadow 0.18s;
      letter-spacing: 0.5px;
    }
    .view-project-btn:hover, .view-project-btn:focus {
      background: var(--primary);
      color: var(--primary-text);
      box-shadow: 0 2px 12px var(--primary-highlight);
    }
    .highlight-section {
      box-shadow: 0 0 0 4px var(--accent), 0 2px 24px var(--primary-highlight);
      transition: box-shadow 0.3s;
      z-index: 10;
      border-radius: 18px;
    }
    .btn-linklike {
      display: inline-block;
      text-align: center;
      text-decoration: none !important;
      appearance: none;
      -webkit-appearance: none;
      -moz-appearance: none;
      border: none;
      outline: none;
      background: var(--secondary);
      color: var(--secondary-text);
      font: inherit;
      cursor: pointer;
      padding: 0.95rem 2.3rem;
      font-size: 1.1rem;
      border-radius: 10px;
      font-weight: 700;
      box-shadow: 0 2px 12px var(--overlay-background);
      min-width: 170px;
      margin-bottom: 0.5rem;
      letter-spacing: 0.5px;
      transition: background 0.18s, color 0.18s, box-shadow 0.18s, transform 0.18s;
    }
    .btn-linklike:hover, .btn-linklike:focus {
      background: var(--secondary-highlight);
      color: var(--accent-text);
      transform: translateY(-2px) scale(1.04);
      box-shadow: 0 4px 18px var(--secondary-highlight);
      text-decoration: none !important;
    }
    /* Neon scrolling text */
    .neon-scroll {
      width: 100vw;
      overflow: hidden;
      white-space: nowrap;
      position: fixed;
      top: 0;
      left: 0;
      z-index: 200;
      pointer-events: none;
    }
    .neon-scroll-text {
      display: inline-block;
      font-family: 'Orbitron', 'Share Tech Mono', monospace;
      font-size: 1.2rem;
      color: #fff;
      text-shadow: 0 0 8px #f53b57, 0 0 16px #3c40c6, 0 0 24px #ffd32a;
      letter-spacing: 2px;
      animation: neon-scroll 18s linear infinite;
      margin-right: 1.5rem;
      margin-bottom: 0;
      position: static;
      transition: transform 0.15s;
    }
    .logo-link:hover .logo {
      box-shadow: 0 6px 32px var(--primary-highlight);
      transform: scale(1.05) rotate(-2deg);
      background: var(--primary-highlight);
    }
    .logo {
      width: 100px;
      height: 100px;
      border-radius: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      background: var(--neon-yellow);
      box-shadow: 0 0 24px 4px var(--neon-blue), 0 0 8px 2px var(--neon-pink);
      transition: box-shadow 0.2s, background 0.2s, transform 0.2s;
    }
    .logo img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      display: block;
    }
    .lang-switcher {
      display: flex;
      gap: 0.5rem;
      background: none;
      box-shadow: none;
      padding: 0;
      border-radius: 0;
      position: static;
    }
    .lang-switcher a {
      color: var(--accent-text);
      background: var(--accent);
      padding: 0.4rem 1.1rem;
      border-radius: 8px;
      text-decoration: none;
      font-weight: 700;
      font-size: var(--medium-font-size);
      transition: background 0.2s, color 0.2s, box-shadow 0.2s;
      box-shadow: 0 2px 8px var(--overlay-background);
      border: 2px solid transparent;
      letter-spacing: 1px;
    }
    .lang-switcher a.active, .lang-switcher a:hover {
      background: var(--primary);
      color: var(--primary-text);
      border-color: var(--primary-highlight);
    }
    .container {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      padding: 2.5rem 1rem 1rem 1rem;
