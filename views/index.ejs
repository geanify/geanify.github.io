<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= t.title %></title>
  <style>
    :root {
      --neutral: #808e9b;
      --neutral-highlight: #d2dae2;
      --neutral-text: #ffffff;
      --primary: #f53b57;
      --primary-highlight: #ef5777;
      --primary-text: #dfbdc4;
      --secondary: #3c40c6;
      --secondary-highlight: #575fcf;
      --secondary-text: #bae2e2;
      --danger: #ff3f34;
      --danger-highlight: #ff5e57;
      --danger-text: #dfaca9;
      --warning: #ffa801;
      --warning-highlight: #ffc048;
      --warning-text: rgb(238, 228, 208);
      --success: #05c46b;
      --success-highlight: #0be881;
      --success-text: #98e4c0;
      --background-dark: #1e272e;
      --background-dark-highlight: #485460;
      --overlay-background: rgba(72, 84, 96, 0.5);
      --accent: #ffd32a;
      --accent-highlight: #ffdd59;
      --accent-text: #ffffff;
      --small-font-size: 14px;
      --medium-font-size: 16px;
      --large-font-size: 18px;
    }
    html, body {
      height: 100%;
      margin: 0;
      padding: 0;
      font-family: 'Segoe UI', 'Roboto', 'Arial', sans-serif;
      background: var(--background-dark);
      color: var(--neutral-text);
      min-height: 100vh;
    }
    body {
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }
    .container {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }
    .logo {
      width: 120px;
      height: 120px;
      margin-bottom: 2rem;
      border-radius: 24px;
      box-shadow: 0 4px 24px var(--overlay-background);
      background: var(--background-dark-highlight);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    .logo img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      display: block;
    }
    h1 {
      font-size: 2.5rem;
      color: var(--primary);
      margin: 0 0 1rem 0;
      letter-spacing: 1px;
      font-weight: 700;
      text-shadow: 0 2px 8px var(--overlay-background);
    }
    p {
      font-size: 1.25rem;
      color: var(--neutral-highlight);
      margin: 0 0 2rem 0;
      max-width: 500px;
      text-align: center;
    }
    .actions {
      display: flex;
      gap: 1rem;
      margin-bottom: 2rem;
    }
    .btn {
      padding: 0.75rem 2rem;
      font-size: var(--medium-font-size);
      border: none;
      border-radius: 8px;
      cursor: pointer;
      font-weight: 600;
      transition: background 0.2s, color 0.2s, box-shadow 0.2s;
      box-shadow: 0 2px 8px var(--overlay-background);
    }
    .btn-primary {
      background: var(--primary);
      color: var(--primary-text);
    }
    .btn-primary:hover {
      background: var(--primary-highlight);
      color: var(--accent-text);
    }
    .btn-secondary {
      background: var(--secondary);
      color: var(--secondary-text);
    }
    .btn-secondary:hover {
      background: var(--secondary-highlight);
      color: var(--accent-text);
    }
    footer {
      text-align: center;
      padding: 1rem 0;
      background: var(--background-dark-highlight);
      color: var(--neutral);
      font-size: var(--small-font-size);
      letter-spacing: 0.5px;
    }
    @media (max-width: 600px) {
      h1 {
        font-size: 2rem;
      }
      .container {
        padding: 1rem;
      }
      .logo {
        width: 80px;
        height: 80px;
      }
    }
    .lang-switcher {
      position: absolute;
      top: 1.5rem;
      right: 2rem;
      z-index: 10;
      display: flex;
      gap: 0.5rem;
    }
    .lang-switcher a {
      color: var(--neutral-highlight);
      background: var(--background-dark-highlight);
      padding: 0.25rem 0.75rem;
      border-radius: 6px;
      text-decoration: none;
      font-weight: 600;
      font-size: var(--medium-font-size);
      transition: background 0.2s, color 0.2s;
    }
    .lang-switcher a.active, .lang-switcher a:hover {
      background: var(--primary);
      color: var(--primary-text);
    }
  </style>
</head>
<body>
  <nav class="lang-switcher">
    <a href="?lang=en" class="<%= lang === 'en' ? 'active' : '' %>">🇬🇧 EN</a>
    <a href="?lang=ro" class="<%= lang === 'ro' ? 'active' : '' %>">🇷🇴 RO</a>
  </nav>
  <div class="container">
    <div class="logo">
      <img src="/logo.png" alt="Web Herald Logo">
    </div>
    <h1><%= t.heading %></h1>
    <p><%= t.description %></p>
    <div class="actions">
      <button class="btn btn-primary">🚀 <%= t.getStarted %></button>
      <button class="btn btn-secondary">📖 <%= t.learnMore %></button>
    </div>
  </div>
  <footer>
    &copy; <%= new Date().getFullYear() %> <%= t.footer %>
  </footer>
</body>
</html> 