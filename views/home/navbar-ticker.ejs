<nav class="navbar">
  <div class="navbar-content">
    <a href="/" class="logo-link">
      <div class="logo">
        <img src="/logo.png" alt="Web Herald Logo">
      </div>
    </a>
    <div class="navbar-spacer"></div>
    <div class="lang-switcher">
      <a href="?lang=en" class="<%= lang === 'en' ? 'active' : '' %>">🇬🇧 EN</a>
      <a href="?lang=ro" class="<%= lang === 'ro' ? 'active' : '' %>">🇷🇴 RO</a>
    </div>
  </div>
</nav>
<div class="stock-ticker-bar">
  <div class="stock-ticker-inner" id="stock-ticker-inner">
    <!-- Stock prices will be injected here by JS -->
    <span>Loading stock prices...</span>
  </div>
</div>
<style>
.stock-ticker-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 9999;
  width: 100vw;
  background: linear-gradient(90deg, #222b3a 0%, #ffd32a 60%, rgba(34,43,58,0.85) 100%);
  color: #1a0033;
  font-family: 'Share Tech Mono', 'Orbitron', monospace;
  font-size: 1.1rem;
  font-weight: 700;
  overflow: hidden;
  height: 2.2rem;
  display: flex;
  align-items: center;
  box-shadow: 0 2px 8px #ffd32a44;
}
.navbar {
  position: sticky;
  top: 2.2rem;
  left: 0;
  right: 0;
  z-index: 101;
}
.stock-ticker-inner {
  display: inline-block;
  white-space: nowrap;
  animation: ticker-scroll 30s linear infinite;
  padding-left: 100vw;
}
@keyframes ticker-scroll {
  0% { transform: translateX(0); }
  100% { transform: translateX(-100%); }
}
.stock-ticker-inner span {
  text-shadow: 1px 1px 2px #000, -1px -1px 2px #000, 1px -1px 2px #000, -1px 1px 2px #000;
  -webkit-text-stroke: 0.5px #000;
  text-stroke: 0.5px #000;
  /* fallback for non-supporting browsers */
}
.stock-up { color: #00e676; font-weight: bold; }
.stock-down { color: #e74c3c; font-weight: bold; }
</style>
<script>
const stocks = [
  { symbol: 'AAPL', name: 'Apple' },
  { symbol: 'GOOGL', name: 'Google' },
  { symbol: 'MSFT', name: 'Microsoft' },
  { symbol: 'AMZN', name: 'Amazon' },
  { symbol: 'META', name: 'Meta' },
  { symbol: 'TSLA', name: 'Tesla' },
  { symbol: 'NVDA', name: 'Nvidia' },
  // Oil companies
  { symbol: 'XOM', name: 'ExxonMobil' },
  { symbol: 'CVX', name: 'Chevron' },
  { symbol: 'BP', name: 'BP' },
  { symbol: 'SHEL', name: 'Shell' },
  { symbol: 'TOT', name: 'TotalEnergies' },
  // Military/defense tech
  { symbol: 'LMT', name: 'Lockheed Martin' },
  { symbol: 'RTX', name: 'Raytheon' },
  { symbol: 'NOC', name: 'Northrop Grumman' },
  { symbol: 'GD', name: 'General Dynamics' },
  { symbol: 'BA', name: 'Boeing' },
  // Food & beverage
  { symbol: 'KO', name: 'Coca-Cola' },
  { symbol: 'PEP', name: 'PepsiCo' },
  { symbol: 'NESN.SW', name: 'Nestle' },
  { symbol: 'MDLZ', name: 'Mondelez' },
  { symbol: 'KHC', name: 'Kraft Heinz' },
];

function getRandomStocks(arr, n) {
  const shuffled = arr.slice().sort(() => 0.5 - Math.random());
  return shuffled.slice(0, n);
}

let lastTickerHTML = '';
async function fetchStockPrices() {
  try {
    const url = `/api/stocks`;
    const res = await fetch(url);
    const data = await res.json();
    // Get all available symbols from the cache object
    const allSymbols = Object.keys(data);
    // Pick 8 random symbols
    const selectedSymbols = getRandomStocks(allSymbols, 8);
    let prices = [];
    prices = selectedSymbols.map(symbol => {
      const quote = data[symbol];
      let price = quote && (quote.close || quote.previous_close);
      let change = quote && quote.percent_change ? parseFloat(quote.percent_change) : null;
      let changeStr = '';
      let cls = '';
      if (change !== null) {
        changeStr = ` (${quote.percent_change}%)`;
        if (change > 0) cls = 'stock-up';
        else if (change < 0) cls = 'stock-down';
      }
      // Try to get the display name from the stocks array, fallback to symbol
      const stockInfo = stocks.find(s => s.symbol === symbol) || { name: symbol, symbol };
      if (price) {
        return `<span class="${cls}">${stockInfo.name} (${symbol}): $${parseFloat(price).toFixed(2)}${changeStr}</span>`;
      } else {
        return `<span>${stockInfo.name} (${symbol}): N/A</span>`;
      }
    });
    const newHTML = prices.join(' &nbsp; | &nbsp; ');
    if (newHTML !== lastTickerHTML) {
      document.getElementById('stock-ticker-inner').innerHTML = newHTML;
      lastTickerHTML = newHTML;
    }
  } catch (e) {
    document.getElementById('stock-ticker-inner').innerHTML = 'Failed to load stock prices.';
  }
}
fetchStockPrices();
setInterval(fetchStockPrices, 60000); // Refresh every 60s
</script> 