<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <!-- SEO Meta Tags -->
  <title><%= t.title %></title>
  <meta name="description" content="<%= t.description %>">
  <meta name="keywords" content="web development, software engineering, cyberpunk design, portfolio, <%= t.heading.toLowerCase() %>">
  <meta name="author" content="Geani">
  <meta name="robots" content="index, follow">
  
  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://web-herald.com/">
  <meta property="og:title" content="<%= t.title %>">
  <meta property="og:description" content="<%= t.description %>">
  <meta property="og:image" content="https://web-herald.com/logo.png">
  <meta property="og:site_name" content="Web Herald">
  
  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image">
  <meta property="twitter:url" content="https://web-herald.com/">
  <meta property="twitter:title" content="<%= t.title %>">
  <meta property="twitter:description" content="<%= t.description %>">
  <meta property="twitter:image" content="https://web-herald.com/logo.png">
  
  <!-- Additional SEO -->
  <meta name="theme-color" content="#f53b57">
  <meta name="msapplication-TileColor" content="#f53b57">
  <link rel="canonical" href="https://web-herald.com/">
  
  <!-- Preload critical resources -->
  <link rel="preload" href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700&family=Share+Tech+Mono&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700&family=Share+Tech+Mono&display=swap"></noscript>
  
  <link rel="icon" type="image/png" href="/logo.png">
  <link rel="apple-touch-icon" href="/logo.png">
  
  <!-- Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Geani",
    "url": "https://web-herald.com",
    "image": "https://web-herald.com/logo.png",
    "sameAs": [
      "mailto:geanify@gmail.com"
    ],
    "jobTitle": "Software Engineer",
    "worksFor": {
      "@type": "Organization",
      "name": "Web Herald"
    },
    "description": "<%= t.description %>"
  }
  </script>
  
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Web Herald",
    "url": "https://web-herald.com",
    "description": "<%= t.description %>",
    "author": {
      "@type": "Person",
      "name": "Geani"
    }
  }
  </script>
  
  <style>
    :root {
      --neutral: #808e9b;
      --neutral-highlight: #d2dae2;
      --neutral-text: #ffffff;
      --primary: #f53b57;
      --primary-highlight: #ef5777;
      --primary-text: #dfbdc4;
      --secondary: #3c40c6;
      --secondary-highlight: #575fcf;
      --secondary-text: #bae2e2;
      --danger: #ff3f34;
      --danger-highlight: #ff5e57;
      --danger-text: #dfaca9;
      --warning: #ffa801;
      --warning-highlight: #ffc048;
      --warning-text: rgb(238, 228, 208);
      --success: #05c46b;
      --success-highlight: #0be881;
      --success-text: #98e4c0;
      --background-dark: #1e272e;
      --background-dark-highlight: #485460;
      --overlay-background: rgba(72, 84, 96, 0.5);
      --accent: #ffd32a;
      --accent-highlight: #ffdd59;
      --accent-text: #ffffff;
      --small-font-size: 14px;
      --medium-font-size: 16px;
      --large-font-size: 18px;
      --neon-pink: #f53b57;
      --neon-green: #05c46b;
    }
    html, body {
      height: 100%;
      margin: 0;
      padding: 0;
      font-family: 'Share Tech Mono', 'Orbitron', 'Segoe UI', 'Roboto', 'Arial', sans-serif;
      background: linear-gradient(120deg, #0f2027 0%, #2c5364 60%, #1a0033 100%);
      color: var(--neutral-text);
      min-height: 100vh;
      max-width: 100vw;
      overflow-x: hidden;
      letter-spacing: 0.5px;
    }
    body {
      display: flex;
      flex-direction: column;
      min-height: 100vh;
      position: relative;
    }
    .lang-switcher {
      position: fixed;
      top: 1rem;
      right: 1rem;
      z-index: 100;
      display: flex;
      gap: 0.5rem;
      background: var(--background-dark-highlight);
      padding: 0.3rem 0.7rem;
      border-radius: 8px;
      box-shadow: 0 2px 8px var(--overlay-background);
    }
    .lang-switcher a {
      color: var(--neutral-highlight);
      background: var(--background-dark-highlight);
      padding: 0.25rem 0.75rem;
      border-radius: 6px;
      text-decoration: none;
      font-weight: 600;
      font-size: var(--medium-font-size);
      transition: background 0.2s, color 0.2s;
    }
    .lang-switcher a.active, .lang-switcher a:hover {
      background: var(--primary);
      color: var(--primary-text);
    }
    .container {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      padding: 2.5rem 1rem 1rem 1rem;
      max-width: 1100px;
      margin: 0 auto;
      width: 100%;
      box-sizing: border-box;
      contain: layout style;
    }
    .logo-link {
      display: flex;
      align-items: center;
      margin-right: 1.5rem;
      margin-bottom: 0;
      position: static;
      transition: transform 0.15s, filter 0.2s;
    }
    .logo {
      width: 100px;
      height: 100px;
      border-radius: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      background: var(--neon-yellow);
      box-shadow: 0 0 24px 4px var(--neon-blue), 0 0 8px 2px var(--neon-pink);
      transition: box-shadow 0.2s, background 0.2s, transform 0.2s;
      will-change: transform, box-shadow;
      contain: layout style paint;
    }
    .logo img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      display: block;
    }
    h1 {
      font-size: 2.7rem;
      color: #ffd32a;
      margin: 0 0 0.7rem 0;
      letter-spacing: 2px;
      font-weight: 900;
      text-shadow: 0 0 16px #f53b57, 0 0 32px #3c40c6, 0 2px 12px #ffd32a;
      text-align: center;
      position: relative;
      z-index: 2;
      font-family: 'Orbitron', 'Share Tech Mono', monospace;
      text-rendering: optimizeLegibility;
      -webkit-font-feature-settings: "kern" 1;
      font-feature-settings: "kern" 1;
    }
    .description {
      font-size: 1.18rem;
      color: #bae2e2;
      margin: 0 0 2.2rem 0;
      max-width: 700px;
      text-align: center;
      line-height: 1.6;
      font-weight: 500;
      text-shadow: 0 0 8px #3c40c6, 0 0 4px #f53b57;
    }
    .actions {
      display: flex;
      gap: 1.2rem;
      margin-bottom: 2.8rem;
      justify-content: center;
      flex-wrap: wrap;
    }
    .btn, .btn-linklike {
      min-width: 200px;
      width: 200px !important;
      box-sizing: border-box;
      padding: 0.95rem 2.3rem;
      font-size: 1.1rem;
      border: none;
      border-radius: 10px;
      cursor: pointer;
      font-weight: 900;
      transition: background 0.18s, color 0.18s, box-shadow 0.18s, transform 0.18s, filter 0.18s;
      box-shadow: 0 0 16px 2px #f53b57, 0 0 8px 2px #3c40c6;
      margin-bottom: 0.5rem;
      background: linear-gradient(90deg, #f53b57 0%, #3c40c6 100%);
      color: #fff;
      letter-spacing: 1.2px;
      text-shadow: 0 0 8px #ffd32a, 0 0 4px #3c40c6;
      font-family: 'Orbitron', 'Share Tech Mono', monospace;
      will-change: transform, box-shadow;
      contain: layout style paint;
    }
    .btn-primary {
      background: linear-gradient(90deg, #f53b57 0%, #ffd32a 100%);
      color: #1a0033;
      border: 2px solid #ffd32a;
    }
    .btn-primary:hover, .btn-primary:focus {
      background: linear-gradient(90deg, #ffd32a 0%, #f53b57 100%);
      color: #fff;
      border-color: #f53b57;
      filter: brightness(1.2) drop-shadow(0 0 8px #ffd32a);
      transform: translateY(-2px) scale(1.04);
      box-shadow: 0 0 32px 8px #f53b57, 0 0 16px 4px #3c40c6;
    }
    .btn-secondary {
      background: linear-gradient(90deg, #3c40c6 0%, #05c46b 100%);
      color: #fff;
      border: 2px solid #05c46b;
    }
    .btn-secondary:hover, .btn-secondary:focus, .btn-linklike:hover, .btn-linklike:focus {
      background: linear-gradient(90deg, #05c46b 0%, #3c40c6 100%);
      color: #ffd32a;
      border-color: #ffd32a;
      filter: brightness(1.2) drop-shadow(0 0 8px #05c46b);
      transform: translateY(-2px) scale(1.04);
      box-shadow: 0 0 32px 8px #3c40c6, 0 0 16px 4px #05c46b;
      text-decoration: none !important;
    }
    .projects-section {
      width: 100%;
      margin-top: 2.5rem;
      margin-bottom: 2rem;
      background: transparent;
      border-radius: 18px;
      box-shadow: none;
      position: relative;
      z-index: 1;
    }
    .projects-title {
      font-size: 1.7rem;
      color: #ffd32a;
      margin-bottom: 1.5rem;
      text-align: center;
      font-weight: 800;
      letter-spacing: 1px;
      text-shadow: 0 2px 8px var(--overlay-background);
    }
    .projects-list {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(290px, 1fr));
      gap: 2rem;
      justify-content: center;
      max-width: 100vw;
      box-sizing: border-box;
      contain: layout style;
    }
    .project-card {
      width: 100%;
      max-width: calc(100vw - 2.5rem);
      box-sizing: border-box;
      background: #1a0033;
      border-radius: 24px;
      box-shadow: 0 0 24px 4px var(--neon-blue), 0 0 8px 2px var(--neon-pink);
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 1.5rem 1rem 1.2rem 1rem;
      border: 3px solid #222b3a;
      min-width: 0;
      position: relative;
      overflow: hidden;
      transition: box-shadow 0.2s, background 0.2s, border-color 0.2s, filter 0.2s, transform 0.2s;
      will-change: transform, box-shadow;
      contain: layout style paint;
    }
    .project-card:hover, .project-card-flashy-neon {
      background: #1a0033;
      box-shadow:
        0 0 48px 12px #00f0ff,
        0 0 32px 8px #f53b57,
        0 0 24px 8px #ffd32a,
        0 0 16px 8px #05c46b;
      border-color: #00f0ff;
      filter: brightness(1.3) saturate(1.5) drop-shadow(0 0 12px #ffd32a);
      transform: scale(1.08) rotate(-2deg);
      animation: project-card-flash 0.4s linear;
      z-index: 2;
    }
    @keyframes project-card-flash {
      0% { box-shadow: 0 0 0 0 #00f0ff, 0 0 0 0 #f53b57, 0 0 0 0 #ffd32a, 0 0 0 0 #05c46b; }
      40% { box-shadow: 0 0 64px 24px #00f0ff, 0 0 48px 16px #f53b57, 0 0 32px 12px #ffd32a, 0 0 24px 8px #05c46b; }
      100% { box-shadow: 0 0 48px 12px #00f0ff, 0 0 32px 8px #f53b57, 0 0 24px 8px #ffd32a, 0 0 16px 8px #05c46b; }
    }
    .project-card::after {
      content: '';
      position: absolute;
      top: -8px; left: -8px; right: -8px; bottom: -8px;
      border-radius: 28px;
      pointer-events: none;
      z-index: 10;
      border: 3px solid #00f0ff;
      box-shadow: 0 0 48px 16px #00f0ff, 0 0 24px 8px #3c40c6;
      opacity: 0;
      transition: opacity 0.2s;
    }
    .project-card:hover::after, .project-card-flashy-neon::after {
      opacity: 1;
      animation: project-card-border-flash 0.4s linear;
    }
    @keyframes project-card-border-flash {
      0% { opacity: 0; }
      40% { opacity: 1; }
      100% { opacity: 1; }
    }
    .project-image {
      width: 90px;
      height: 90px;
      border-radius: 12px;
      background: transparent;
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      box-shadow: 0 2px 8px var(--overlay-background);
    }
    .project-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      background: transparent;
    }
    .project-title {
      font-size: 1.2rem;
      color: #ffd32a;
      font-weight: 700;
      margin-bottom: 0.5rem;
      text-align: center;
      letter-spacing: 0.5px;
      font-family: 'Orbitron', 'Share Tech Mono', monospace;
      text-shadow: 0 0 8px #f53b57, 0 0 4px #3c40c6;
      text-rendering: optimizeLegibility;
      -webkit-font-feature-settings: "kern" 1;
      font-feature-settings: "kern" 1;
    }
    .project-description {
      color: #bae2e2;
      font-size: 1rem;
      text-align: center;
      margin-bottom: 0.5rem;
      font-weight: 500;
      text-shadow: 0 0 8px #3c40c6, 0 0 4px #f53b57;
    }
    .project-card-link {
      display: block;
      text-decoration: none !important;
      color: inherit !important;
      cursor: pointer;
    }
    .project-card-link:visited,
    .project-card-link:active,
    .project-card-link:focus {
      color: inherit !important;
      text-decoration: none !important;
      outline: none;
    }
    .project-card-link .project-card,
    .project-card-link .project-card:hover {
      box-shadow: 0 0 24px 4px #3c40c6, 0 0 8px 2px #f53b57;
      border-color: #ffd32a;
      background: #1a0033;
      transition: box-shadow 0.2s, border-color 0.2s, background 0.2s;
    }
    footer {
      text-align: center;
      padding: 1.5rem 0 1rem 0;
      background: var(--background-dark-highlight);
      color: var(--neutral);
      font-size: var(--small-font-size);
      letter-spacing: 0.5px;
      box-shadow: 0 -2px 12px var(--background-dark-highlight);
      margin-top: 3rem;
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
    }
    @media (max-width: 900px) {
      .projects-list {
         flex-direction: column;
         align-items: center;
         max-width: 100vw;
      }
      .project-card {
         width: 100%;
         max-width: calc(100vw - 2.5rem);
         box-sizing: border-box;
      }
    }
    @media (max-width: 600px) {
      .project-card {
        will-change: auto;
        contain: layout style;
      }
      
      .btn, .btn-linklike {
        will-change: auto;
        contain: layout style;
      }
      
      /* Reduce animations on mobile for better performance */
      .project-card:hover, .project-card-flashy-neon {
        transform: scale(1.02);
        animation: none;
      }
      
      .logo-link:hover .logo {
        transform: scale(1.02);
      }
      
      /* Optimize font loading */
      h1 {
        font-size: 1.3rem;
        font-display: swap;
      }
      
      .container {
        padding: 1rem 0.5rem 0.5rem 0.5rem;
        max-width: 100vw;
      }
      
      .logo {
        width: 70px;
        height: 70px;
      }
      
      .projects-title {
        font-size: 1.2rem;
      }
      
      .actions {
        flex-direction: column;
        gap: 0.5rem;
        align-items: stretch;
      }
      
      .btn, .btn-linklike {
        width: 100%;
        min-width: 0;
        font-size: 1rem;
        padding: 0.9rem 0.5rem;
      }
      
      .lang-switcher {
        top: 0.5rem;
        right: 0.5rem;
        padding: 0.2rem 0.4rem;
        font-size: 0.95rem;
      }
      
      .project-card {
        width: 100%;
        max-width: calc(100vw - 1.2rem);
        margin-left: auto;
        margin-right: auto;
      }
      
      .project-image {
        width: 60px;
        height: 60px;
      }
      
      .navbar {
        max-width: 100vw;
      }
      
      .navbar-content {
        max-width: 100vw;
      }
      
      .projects-list {
        max-width: 100vw;
      }
      
      .project-card {
        max-width: calc(100vw - 1.2rem);
      }
    }
    .navbar {
      width: 100vw;
      max-width: 100vw;
      left: 0;
      right: 0;
      top: 0;
      background: rgba(20, 10, 40, 0.92);
      box-shadow: 0 2px 32px 0 #f53b57cc, 0 0px 0px 2px #3c40c6cc;
      min-height: 120px;
      display: flex;
      align-items: center;
      justify-content: center;
      position: sticky;
      z-index: 100;
      margin-bottom: 2rem;
      backdrop-filter: blur(8px);
      border-bottom: 2px solid #f53b57;
      transition: background 0.3s;
    }
    .navbar-content {
      min-height: 120px;
      align-items: center;
      width: 100%;
      max-width: 1100px;
      box-sizing: border-box;
      display: flex;
      gap: 0.5rem;
      justify-content: space-between;
      padding: 0.2rem 1.5rem;
      font-family: 'Orbitron', 'Share Tech Mono', monospace;
    }
    .logo-link:hover .logo {
      box-shadow: 0 0 32px 8px #f53b57, 0 0 16px 4px #3c40c6;
      filter: brightness(1.3) saturate(1.5) drop-shadow(0 0 12px #ffd32a);
      transform: scale(1.08) rotate(-2deg);
      background: #1a0033;
    }
    .hero {
      width: 100%;
      margin-bottom: 2.5rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      position: relative;
      z-index: 1;
      font-family: 'Orbitron', 'Share Tech Mono', monospace;
    }
    .hero-underline {
      width: 120px;
      height: 8px;
      background: linear-gradient(90deg, #f53b57, #ffd32a, #3c40c6);
      border-radius: 4px;
      margin: 0.5rem auto 1.2rem auto;
      box-shadow: 0 0 16px #f53b57, 0 0 16px #3c40c6;
      opacity: 0.95;
      animation: neon-underline 2.5s infinite alternate;
      will-change: filter;
      contain: layout style paint;
    }
    @keyframes neon-underline {
      0% { filter: brightness(1.2) drop-shadow(0 0 8px #ffd32a); }
      100% { filter: brightness(2.2) drop-shadow(0 0 24px #3c40c6); }
    }
    .view-project-btn {
      margin-top: 0.7rem;
      padding: 0.5rem 1.2rem;
      background: var(--accent);
      color: var(--accent-text);
      border: none;
      border-radius: 7px;
      font-weight: 700;
      font-size: 1rem;
      cursor: pointer;
      box-shadow: 0 1px 6px var(--overlay-background);
      transition: background 0.18s, color 0.18s, box-shadow 0.18s;
      letter-spacing: 0.5px;
    }
    .view-project-btn:hover, .view-project-btn:focus {
      background: var(--primary);
      color: var(--primary-text);
      box-shadow: 0 2px 12px var(--primary-highlight);
    }
    .highlight-section {
      box-shadow: 0 0 0 4px var(--accent), 0 2px 24px var(--primary-highlight);
      transition: box-shadow 0.3s;
      z-index: 10;
      border-radius: 18px;
    }
    .btn-linklike {
      display: inline-block;
      text-align: center;
      text-decoration: none !important;
      appearance: none;
      -webkit-appearance: none;
      -moz-appearance: none;
      border: none;
      outline: none;
      background: var(--secondary);
      color: var(--secondary-text);
      font: inherit;
      cursor: pointer;
      padding: 0.95rem 2.3rem;
      font-size: 1.1rem;
      border-radius: 10px;
      font-weight: 700;
      box-shadow: 0 2px 12px var(--overlay-background);
      min-width: 170px;
      margin-bottom: 0.5rem;
      letter-spacing: 0.5px;
      transition: background 0.18s, color 0.18s, box-shadow 0.18s, transform 0.18s;
    }
    .btn-linklike:hover, .btn-linklike:focus {
      background: var(--secondary-highlight);
      color: var(--accent-text);
      transform: translateY(-2px) scale(1.04);
      box-shadow: 0 4px 18px var(--secondary-highlight);
      text-decoration: none !important;
    }
    /* Neon scrolling text */
    .neon-scroll {
      width: 100vw;
      overflow: hidden;
      white-space: nowrap;
      position: fixed;
      top: 0;
      left: 0;
      z-index: 200;
      pointer-events: none;
    }
    .neon-scroll-text {
      display: inline-block;
      font-family: 'Orbitron', 'Share Tech Mono', monospace;
      font-size: 1.2rem;
      color: #fff;
      text-shadow: 0 0 8px #f53b57, 0 0 16px #3c40c6, 0 0 24px #ffd32a;
      letter-spacing: 2px;
      animation: neon-scroll 18s linear infinite;
      margin-right: 1.5rem;
      margin-bottom: 0;
      position: static;
      transition: transform 0.15s;
    }
    .logo-link:hover .logo {
      box-shadow: 0 6px 32px var(--primary-highlight);
      transform: scale(1.05) rotate(-2deg);
      background: var(--primary-highlight);
    }
    .logo {
      width: 100px;
      height: 100px;
      border-radius: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      background: var(--neon-yellow);
      box-shadow: 0 0 24px 4px var(--neon-blue), 0 0 8px 2px var(--neon-pink);
      transition: box-shadow 0.2s, background 0.2s, transform 0.2s;
    }
    .logo img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      display: block;
    }
    .lang-switcher {
      display: flex;
      gap: 0.5rem;
      background: none;
      box-shadow: none;
      padding: 0;
      border-radius: 0;
      position: static;
    }
    .lang-switcher a {
      color: var(--accent-text);
      background: var(--accent);
      padding: 0.4rem 1.1rem;
      border-radius: 8px;
      text-decoration: none;
      font-weight: 700;
      font-size: var(--medium-font-size);
      transition: background 0.2s, color 0.2s, box-shadow 0.2s;
      box-shadow: 0 2px 8px var(--overlay-background);
      border: 2px solid transparent;
      letter-spacing: 1px;
    }
    .lang-switcher a.active, .lang-switcher a:hover {
      background: var(--primary);
      color: var(--primary-text);
      border-color: var(--primary-highlight);
    }
    .container {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      padding: 2.5rem 1rem 1rem 1rem;
      max-width: 1100px;
      margin: 0 auto;
      width: 100%;
      box-sizing: border-box;
    }
    .hero {
      width: 100%;
      margin-bottom: 2.5rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      position: relative;
      z-index: 1;
    }
    h1 {
      font-size: 2.5rem;
      color: var(--primary);
      margin: 0 0 0.7rem 0;
      letter-spacing: 1px;
      font-weight: 800;
      text-shadow: 0 2px 12px var(--overlay-background);
      text-align: center;
      position: relative;
      z-index: 2;
    }
    .hero-underline {
      width: 80px;
      height: 6px;
      background: linear-gradient(90deg, var(--accent), var(--primary-highlight));
      border-radius: 3px;
      margin: 0.5rem auto 1.2rem auto;
      box-shadow: 0 2px 8px var(--primary-highlight);
      opacity: 0.85;
    }
    .description {
      font-size: 1.18rem;
      color: var(--neutral-highlight);
      margin: 0 0 2.2rem 0;
      max-width: 700px;
      text-align: center;
      line-height: 1.6;
      font-weight: 500;
    }
    .actions {
      display: flex;
      gap: 1.2rem;
      margin-bottom: 2.8rem;
      justify-content: center;
      flex-wrap: wrap;
    }
    .btn {
      padding: 0.95rem 2.3rem;
      font-size: 1.1rem;
      border: none;
      border-radius: 10px;
      cursor: pointer;
      font-weight: 700;
      transition: background 0.18s, color 0.18s, box-shadow 0.18s, transform 0.18s;
      box-shadow: 0 2px 12px var(--overlay-background);
      min-width: 170px;
      margin-bottom: 0.5rem;
      background: var(--primary);
      color: var(--primary-text);
      letter-spacing: 0.5px;
    }
    .btn-primary {
      background: var(--primary);
      color: var(--primary-text);
    }
    .btn-primary:hover, .btn-primary:focus {
      background: var(--primary-highlight);
      color: var(--accent-text);
      transform: translateY(-2px) scale(1.04);
      box-shadow: 0 4px 18px var(--primary-highlight);
    }
    .btn-secondary {
      background: var(--secondary);
      color: var(--secondary-text);
    }
    .btn-secondary:hover, .btn-secondary:focus {
      background: var(--secondary-highlight);
      color: var(--accent-text);
      transform: translateY(-2px) scale(1.04);
      box-shadow: 0 4px 18px var(--secondary-highlight);
    }
    .projects-section {
      width: 100%;
      margin-top: 2.5rem;
      margin-bottom: 2rem;
      background: var(--neon-yellow);
      border-radius: 18px;
      box-shadow: 0 0 32px 8px var(--neon-blue), 0 0 16px 4px var(--neon-pink);
      position: relative;
      z-index: 1;
    }
    .projects-title {
      font-size: 1.7rem;
      color: var(--accent);
      margin-bottom: 1.5rem;
      text-align: center;
      font-weight: 800;
      letter-spacing: 1px;
      text-shadow: 0 2px 8px var(--overlay-background);
    }
    .projects-list {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(290px, 1fr));
      gap: 2rem;
      justify-content: center;
      max-width: 100vw;
      box-sizing: border-box;
    }
    .project-card-link {
      display: block;
      text-decoration: none !important;
      color: inherit !important;
      cursor: pointer;
    }
    .project-card-link:visited,
    .project-card-link:active,
    .project-card-link:focus {
      color: inherit !important;
      text-decoration: none !important;
      outline: none;
    }
    .project-card-link .project-card,
    .project-card-link .project-card:hover {
      box-shadow: 0 0 24px 4px #3c40c6, 0 0 8px 2px #f53b57;
      border-color: #ffd32a;
      background: #1a0033;
      transition: box-shadow 0.2s, border-color 0.2s, background 0.2s;
    }
    .project-card {
      width: 100%;
      max-width: calc(100vw - 2.5rem);
      box-sizing: border-box;
      background: var(--background-dark-highlight);
      border-radius: 18px;
      box-shadow: 0 2px 12px var(--overlay-background);
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 1.5rem 1rem 1.2rem 1rem;
      transition: transform 0.15s, box-shadow 0.15s;
      border: 2px solid transparent;
      min-width: 0;
      position: relative;
      overflow: hidden;
    }
    .project-card:hover,
    .project-card-flashy-neon {
      transform: scale(1.08) rotate(-2deg);
      z-index: 2;
    }
    .project-image {
      width: 90px;
      height: 90px;
      border-radius: 12px;
      background: var(--neutral-highlight);
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      box-shadow: 0 2px 8px var(--overlay-background);
    }
    .project-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      background: var(--neutral-highlight);
    }
    .project-title {
      font-size: 1.2rem;
      color: var(--primary);
      font-weight: 700;
      margin-bottom: 0.5rem;
      text-align: center;
      letter-spacing: 0.5px;
    }
    .project-description {
      color: var(--neutral-highlight);
      font-size: 1rem;
      text-align: center;
      margin-bottom: 0.5rem;
      font-weight: 500;
    }
    .view-project-btn {
      margin-top: 0.7rem;
      padding: 0.5rem 1.2rem;
      background: var(--accent);
      color: var(--accent-text);
      border: none;
      border-radius: 7px;
      font-weight: 700;
      font-size: 1rem;
      cursor: pointer;
      box-shadow: 0 1px 6px var(--overlay-background);
      transition: background 0.18s, color 0.18s, box-shadow 0.18s;
      letter-spacing: 0.5px;
    }
    .view-project-btn:hover, .view-project-btn:focus {
      background: var(--primary);
      color: var(--primary-text);
      box-shadow: 0 2px 12px var(--primary-highlight);
    }
    footer {
      text-align: center;
      padding: 1.5rem 0 1rem 0;
      background: var(--background-dark-highlight);
      color: var(--neutral);
      font-size: var(--small-font-size);
      letter-spacing: 0.5px;
      box-shadow: 0 -2px 12px var(--background-dark-highlight);
      margin-top: 3rem;
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
    }
    @media (max-width: 900px) {
      .projects-list {
         flex-direction: column;
         align-items: center;
         max-width: 100vw;
      }
      .project-card {
         width: 100%;
         max-width: calc(100vw - 2.5rem);
         box-sizing: border-box;
      }
    }
    @media (max-width: 600px) {
      .container {
         padding: 1rem 0.5rem 0.5rem 0.5rem;
         max-width: 100vw;
      }
      .hero-underline {
         width: 50px;
         height: 4px;
      }
      .logo {
         width: 70px;
         height: 70px;
      }
      .projects-title {
         font-size: 1.2rem;
      }
      .navbar {
         max-width: 100vw;
         min-height: 80px;
      }
      .navbar-content {
         max-width: 100vw;
         min-height: 80px;
         padding: 0.2rem 0.5rem;
      }
      .projects-list {
         max-width: 100vw;
         grid-template-columns: 1fr;
      }
      .project-card {
         width: 100%;
         max-width: calc(100vw - 1.2rem);
         margin-left: auto;
         margin-right: auto;
      }
    }
    .highlight-section {
      box-shadow: 0 0 0 4px var(--accent), 0 2px 24px var(--primary-highlight);
      transition: box-shadow 0.3s;
      z-index: 10;
      border-radius: 18px;
    }
    .btn-linklike {
      display: inline-block;
      text-align: center;
      text-decoration: none !important;
      appearance: none;
      -webkit-appearance: none;
      -moz-appearance: none;
      border: none;
      outline: none;
      background: var(--secondary);
      color: var(--secondary-text);
      font: inherit;
      cursor: pointer;
      padding: 0.95rem 2.3rem;
      font-size: 1.1rem;
      border-radius: 10px;
      font-weight: 700;
      box-shadow: 0 2px 12px var(--overlay-background);
      min-width: 170px;
      margin-bottom: 0.5rem;
      letter-spacing: 0.5px;
      transition: background 0.18s, color 0.18s, box-shadow 0.18s, transform 0.18s;
    }
    .btn-linklike:hover, .btn-linklike:focus {
      background: var(--secondary-highlight);
      color: var(--accent-text);
      transform: translateY(-2px) scale(1.04);
      box-shadow: 0 4px 18px var(--secondary-highlight);
      text-decoration: none !important;
    }
    .logo-tap-neon {
      box-shadow: 0 0 32px 8px var(--neon-pink), 0 0 16px 4px var(--neon-blue), 0 0 12px 4px var(--neon-yellow) !important;
      filter: brightness(1.3) saturate(1.5) drop-shadow(0 0 12px var(--neon-yellow));
      background: var(--neon-bg) !important;
      transition: box-shadow 0.2s, background 0.2s, filter 0.2s;
    }
    .project-card-flashy-neon {
      box-shadow: 0 0 32px 8px var(--neon-pink), 0 0 32px 8px var(--neon-blue), 0 0 24px 8px var(--neon-yellow), 0 0 16px 8px var(--neon-green) !important;
      filter: brightness(1.3) saturate(1.5) drop-shadow(0 0 12px var(--neon-yellow));
      background: linear-gradient(120deg, var(--neon-blue) 0%, #1a0033 100%);
      animation: project-card-neon-bg-blue 0.5s linear;
      transition: box-shadow 0.2s, background 0.2s, filter 0.2s;
    }
    @keyframes project-card-neon-bg-blue {
      0% { background: linear-gradient(120deg, var(--neon-yellow) 0%, var(--neon-pink) 50%, var(--neon-blue) 100%); }
      100% { background: linear-gradient(120deg, var(--neon-blue) 0%, #1a0033 100%); }
    }
    .project-card-flashy-neon::after {
      content: '';
      position: absolute;
      top: -6px; left: -6px; right: -6px; bottom: -6px;
      border-radius: 22px;
      pointer-events: none;
      z-index: 10;
      border: 3px solid #00f0ff;
      box-shadow: 0 0 32px 12px #00f0ff, 0 0 24px 8px #3c40c6;
      opacity: 1;
      filter: blur(2px) brightness(1.5) saturate(2);
      transition: box-shadow 0.2s, border-color 0.2s, opacity 0.2s;
    }
    @media (min-width: 1000px) {
      .side-banners { 
        display: flex !important; 
        position: fixed;
        top: 50%;
        transform: translateY(-50%);
        z-index: 50;
        width: 320px;
        max-width: 22vw;
      }
      .side-banners:first-of-type {
        left: 0;
        margin-left: 0 !important;
        margin-right: 0 !important;
        align-items: flex-start;
      }
      .side-banners:last-of-type {
        right: 0;
        margin-right: 0 !important;
        margin-left: 0 !important;
        align-items: flex-end;
      }
      .mobile-banners {
      }
      .projects-list-wrapper {
        margin-left: 340px !important;
        margin-right: 340px !important;
        width: auto !important;
      }
      .projects-list { grid-template-columns: repeat(auto-fit, minmax(290px, 1fr)); }
    }
    @media (max-width: 999px) {
      .side-banners {
        display: none !important;
      }
      .mobile-banners {
        display: flex !important;
        padding: 0 1rem;
        margin: 1.5rem 0;
        box-sizing: border-box;
      }
    }
    @media (min-width: 1000px) {
      .mobile-banners {
        display: none !important;
      }
      .side-banners {
        display: flex !important;
      }
    }
    .coming-soon-message {
      text-align: center;
      font-size: 2rem;
      color: #ffd32a;
      font-family: 'Orbitron', 'Share Tech Mono', monospace;
      margin: 2.5rem 0;
      font-weight: bold;
      text-shadow: 0 0 8px #3c40c6, 0 0 4px #f53b57;
    }
    /* CRT TV Effect for Banner Ads */
    .crt-effect {
      position: relative;
      overflow: hidden;
      border-radius: 18px;
      box-shadow: 0 0 32px 4px #fff8, 0 0 0 4px #2228, 0 0 24px 8px #00f2ff44;
      filter: contrast(1.15) saturate(0.92) brightness(1.08);
      background-clip: padding-box;
      /* Slight curve */
      box-shadow: 0 0 32px 4px #fff8, 0 0 0 4px #2228, 0 0 24px 8px #00f2ff44, inset 0 0 60px #fff2, inset 0 0 120px #00f2ff22;
    }
    .crt-effect::before {
      content: '';
      pointer-events: none;
      position: absolute;
      left: 0; top: 0; right: 0; bottom: 0;
      z-index: 2;
      background:
        repeating-linear-gradient(
          to bottom,
          rgba(255,255,255,0.07) 0px,
          rgba(255,255,255,0.07) 1px,
          transparent 2px,
          transparent 4px
        );
      mix-blend-mode: screen;
      opacity: 0.45;
    }
    .crt-effect::after {
      content: '';
      pointer-events: none;
      position: absolute;
      left: 0; top: 0; right: 0; bottom: 0;
      z-index: 3;
      background:
        radial-gradient(ellipse at center, rgba(255,255,255,0.10) 0%, rgba(0,0,0,0.18) 100%);
      border-radius: 18px;
      opacity: 0.7;
      box-shadow: 0 0 32px 8px #fff2 inset;
    }
    @keyframes crt-flicker {
      0% { filter: brightness(1.04) hue-rotate(0deg); }
      20% { filter: brightness(0.98) hue-rotate(-2deg); }
      40% { filter: brightness(1.08) hue-rotate(2deg); }
      60% { filter: brightness(1.01) hue-rotate(-1deg); }
      80% { filter: brightness(1.06) hue-rotate(1deg); }
      100% { filter: brightness(1.04) hue-rotate(0deg); }
    }
    .crt-effect {
      animation: crt-flicker 0.18s infinite linear;
    }
    
    /* Banner styling with new class name to avoid ad blockers */
    .content-promo {
      background: linear-gradient(135deg, #ffd32a 0%, #f53b57 50%, #3c40c6 100%);
      color: #1a0033;
      border-radius: 18px;
      padding: 1.5rem;
      text-align: center;
      font-weight: bold;
      min-height: 200px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      box-shadow: 0 0 32px 4px #fff8, 0 0 0 4px #2228, 0 0 24px 8px #00f2ff44;
      position: relative;
      overflow: hidden;
      transition: transform 0.3s, box-shadow 0.3s;
    }
    
    .content-promo:hover {
      transform: scale(1.02);
      box-shadow: 0 0 48px 8px #fff8, 0 0 0 4px #2228, 0 0 32px 12px #00f2ff44;
    }
    
    .content-promo-title {
      font-size: 1.2rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      text-shadow: 0 2px 4px rgba(0,0,0,0.3);
    }
    
    .content-promo-description {
      font-size: 0.9rem;
      margin-bottom: 1rem;
      opacity: 0.9;
    }
    
    .content-promo-cta {
      background: rgba(255,255,255,0.9);
      color: #1a0033;
      padding: 0.5rem 1rem;
      border-radius: 8px;
      text-decoration: none;
      font-weight: 600;
      transition: background 0.2s;
    }
    
    .content-promo-cta:hover {
      background: rgba(255,255,255,1);
      text-decoration: none;
    }
    
    /* Alternative class names to avoid ad blockers */
    .promo-box, .feature-box, .highlight-box {
      background: linear-gradient(135deg, #ffd32a 0%, #f53b57 50%, #3c40c6 100%);
      color: #1a0033;
      border-radius: 18px;
      padding: 1.5rem;
      text-align: center;
      font-weight: bold;
      min-height: 200px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      box-shadow: 0 0 32px 4px #fff8, 0 0 0 4px #2228, 0 0 24px 8px #00f2ff44;
      position: relative;
      overflow: hidden;
      transition: transform 0.3s, box-shadow 0.3s;
    }
    
    .promo-box:hover, .feature-box:hover, .highlight-box:hover {
      transform: scale(1.02);
      box-shadow: 0 0 48px 8px #fff8, 0 0 0 4px #2228, 0 0 32px 12px #00f2ff44;
    }
    
    /* Force display for all banner-like elements */
    .content-promo, .promo-box, .feature-box, .highlight-box {
      display: flex !important;
      visibility: visible !important;
      opacity: 1 !important;
    }
  </style>
</head>
<body>
  <%- include('home/navbar-ticker.ejs', { lang }) %>
  
  <main class="container" role="main">
    <!-- Cyberpunk Smoke Effect Canvas -->
    <canvas id="cyberpunk-smoke" width="600" height="400" style="position: fixed; right: 0; bottom: 0; pointer-events: none; z-index: 10;" aria-hidden="true"></canvas>
    
    <section class="hero" role="banner">
      <h1><%= t.heading %></h1>
      <div class="hero-underline" aria-hidden="true"></div>
      <p class="description"><%= t.description %></p>
      <div class="actions" role="group" aria-label="Main actions">
        <button class="btn btn-primary" id="our-work-btn" aria-label="<%= t.getStarted %>">🛠️ <%= t.getStarted %></button>
        <a class="btn btn-secondary btn-linklike" href="mailto:geanify@gmail.com" role="button" tabindex="0" aria-label="<%= t.learnMore %>">✉️ <%= t.learnMore %></a>
      </div>
    </section>
    
    <section class="projects-section" role="region" aria-labelledby="projects-heading">
      <h2 id="projects-heading" class="projects-title"><%= t.projectsHeading %></h2>
      <div class="projects-list-wrapper" style="display: flex; flex-direction: row; justify-content: center; align-items: flex-start; width: 100%;">
        <!-- Desktop left banner -->
        <aside class="side-banners" style="flex-direction: column; gap: 2rem; margin-right: 2rem;" aria-label="Promotional content">
          <%- include('home/banner-ad.ejs', { type: 'overconsumption', t: t }) %>
        </aside>
        
        <div class="projects-list" style="flex: 1;" role="list">
          <% if (t.projects.length === 0) { %>
            <div class="coming-soon-message" role="status"><%= t.comingSoon %></div>
          <% } else { %>
            <!-- Mobile banners always shown on mobile -->
            <aside class="mobile-banners" style="flex-direction: column; gap: 1.5rem; margin: 1.5rem 0;" aria-label="Promotional content">
              <%- include('home/banner-ad.ejs', { type: 'overconsumption', t: t }) %>
              <%- include('home/banner-ad.ejs', { type: 'subscriptions', t: t }) %>
            </aside>
            
            <% t.projects.forEach(function(project, idx) { %>
              <%- include('home/project-card.ejs', { project }) %>
            <% }); %>
          <% } %>
        </div>
        
        <!-- Desktop right banner -->
        <aside class="side-banners" style="flex-direction: column; gap: 2rem; margin-left: 2rem;" aria-label="Promotional content">
          <%- include('home/banner-ad.ejs', { type: 'subscriptions', t: t }) %>
        </aside>
      </div>
    </section>
  </main>
  
  <footer role="contentinfo">
    <p>&copy; <%= new Date().getFullYear() %> <%= t.footer %></p>
  </footer>
  
  <!-- Performance optimized scripts -->
  <script>
    // Smooth scroll and highlight for Our Work button
    document.addEventListener('DOMContentLoaded', function() {
      var btn = document.getElementById('our-work-btn');
      var section = document.querySelector('.projects-section');
      if (btn && section) {
        btn.addEventListener('click', function(e) {
          e.preventDefault();
          section.scrollIntoView({ behavior: 'smooth', block: 'center' });
          section.classList.add('highlight-section');
          setTimeout(function() {
            section.classList.remove('highlight-section');
          }, 1200);
        });
      }
    });
    
    // Neon effect on logo tap for mobile
    document.addEventListener('DOMContentLoaded', function() {
      var logo = document.querySelector('.logo');
      if (logo) {
        var addNeon = function() {
          logo.classList.add('logo-tap-neon');
          setTimeout(function() {
            logo.classList.remove('logo-tap-neon');
          }, 400);
        };
        logo.addEventListener('touchstart', addNeon);
      }

      // Neon effect on project card tap/click/hover
      var cards = document.querySelectorAll('.project-card');
      cards.forEach(function(card) {
        var animate = function() {
          card.classList.add('project-card-flashy-neon');
          setTimeout(function() {
            card.classList.remove('project-card-flashy-neon');
          }, 400);
        };
        card.addEventListener('touchstart', animate);
        card.addEventListener('mousedown', animate);
        card.addEventListener('mouseenter', animate);
      });
    });
    
    // Performance optimization: Intersection Observer for smoke effect
    document.addEventListener('DOMContentLoaded', function() {
      const canvas = document.getElementById('cyberpunk-smoke');
      if (canvas && 'IntersectionObserver' in window) {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              canvas.style.display = 'block';
            } else {
              canvas.style.display = 'none';
            }
          });
        }, { threshold: 0.1 });
        observer.observe(canvas);
      }
    });
  </script>
  
  <!-- Load smoke effect asynchronously -->
  <script src="/smoke-effect.js" async defer></script>
</body>
</html> 