<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Interlinked - <%= t.title %></title>
  <meta name="description" content="<%= t.projects[1].description %>">
  <meta name="keywords" content="interlinked, digital identity, networks, society, <%= t.title.toLowerCase() %>">
  <meta name="author" content="Geani">
  <meta name="robots" content="index, follow">
  <meta name="theme-color" content="#f53b57">
  <link rel="canonical" href="https://web-herald.com/interlinked">
  <link rel="preload" href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700&family=Share+Tech+Mono&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700&family=Share+Tech+Mono&display=swap"></noscript>
  <link rel="icon" type="image/png" href="/logo.png">
  <link rel="apple-touch-icon" href="/logo.png">
  <style>
    :root {
      --neutral: #808e9b;
      --neutral-highlight: #d2dae2;
      --neutral-text: #ffffff;
      --primary: #f53b57;
      --primary-highlight: #ef5777;
      --primary-text: #dfbdc4;
      --secondary: #3c40c6;
      --secondary-highlight: #575fcf;
      --secondary-text: #bae2e2;
      --danger: #ff3f34;
      --danger-highlight: #ff5e57;
      --danger-text: #dfaca9;
      --warning: #ffa801;
      --warning-highlight: #ffc048;
      --warning-text: rgb(238, 228, 208);
      --success: #05c46b;
      --success-highlight: #0be881;
      --success-text: #98e4c0;
      --background-dark: #1e272e;
      --background-dark-highlight: #485460;
      --overlay-background: rgba(72, 84, 96, 0.5);
      --accent: #ffd32a;
      --accent-highlight: #ffdd59;
      --accent-text: #ffffff;
      --small-font-size: 14px;
      --medium-font-size: 16px;
      --large-font-size: 18px;
    }
    html, body {
      height: 100%;
      margin: 0;
      padding: 0;
      font-family: 'Share Tech Mono', 'Orbitron', 'Segoe UI', 'Roboto', 'Arial', sans-serif;
      background: linear-gradient(120deg, #0f2027 0%, #2c5364 60%, #1a0033 100%);
      color: var(--neutral-text);
      min-height: 100vh;
      max-width: 100vw;
      overflow-x: hidden;
      letter-spacing: 0.5px;
    }
    body {
      display: flex;
      flex-direction: column;
      min-height: 100vh;
      position: relative;
    }
    .container {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      padding: 2.5rem 1rem 1rem 1rem;
      max-width: 1100px;
      margin: 0 auto;
      width: 100%;
      box-sizing: border-box;
      contain: layout style;
    }
    .hero {
      width: 100%;
      margin-bottom: 1rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      position: relative;
      z-index: 1;
      font-family: 'Orbitron', 'Share Tech Mono', monospace;
    }
    .hero-underline {
      width: 120px;
      height: 8px;
      background: linear-gradient(90deg, #f53b57, #ffd32a, #3c40c6);
      border-radius: 4px;
      margin: 0.5rem auto 1.2rem auto;
      box-shadow: 0 0 16px #f53b57, 0 0 16px #3c40c6;
      opacity: 0.95;
      animation: neon-underline 2.5s infinite alternate;
      will-change: filter;
      contain: layout style paint;
    }
    @keyframes neon-underline {
      0% { filter: brightness(1.2) drop-shadow(0 0 8px #ffd32a); }
      100% { filter: brightness(2.2) drop-shadow(0 0 24px #3c40c6); }
    }
    .interlinked-section-card {
      background: var(--background-dark-highlight);
      border-radius: 18px;
      box-shadow: 0 4px 32px var(--overlay-background);
      margin: 0 auto 2rem auto;
      max-width: 700px;
      padding: 0;
      overflow: hidden;
    }
    .interlinked-heading-image-wrapper {
      width: 100%;
      height: 180px;
      background: var(--secondary);
      display: flex;
      align-items: flex-end;
      justify-content: center;
      position: relative;
    }
    .interlinked-heading-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0.85;
      border-bottom: 3px solid var(--primary);
    }
    .interlinked-heading-overlay {
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      background: linear-gradient(0deg, #1a0033 80%, transparent 100%);
      padding: 1.2rem 0 0.5rem 0;
      text-align: center;
    }
    .interlinked-heading-overlay h2 {
      color: var(--secondary-highlight);
      font-size: 1.5rem;
      font-family: 'Orbitron', 'Share Tech Mono', monospace;
      margin: 0;
      letter-spacing: 0.08em;
      text-shadow: 0 2px 8px var(--primary), 0 0 2px var(--secondary);
    }
    .interlinked-section-content {
      padding: 2rem 2.5rem 2.5rem 2.5rem;
      font-size: 1.18rem;
      color: var(--neutral-highlight);
      font-family: 'Orbitron', 'Share Tech Mono', monospace;
      line-height: 1.7;
      text-align: center;
    }
    .interlink-form {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.2rem;
    }
    .interlink-input-row {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.7rem;
      width: 100%;
      justify-content: center;
    }
    .input-wrap {
      flex: 1 1 40px;
      min-width: 120px;
      max-width: 220px;
      display: flex;
      flex-direction: column;
    }
    .interlink-input-row input {
      font-size: 1rem;
      padding: 0.4rem 0.8rem;
      border-radius: 8px;
      border: 2px solid var(--secondary);
      background: var(--background-dark);
      color: var(--secondary-highlight);
      outline: none;
      min-width: 120px;
      max-width: 220px;
      flex: 1 1 40px;
      transition: border 0.2s, box-shadow 0.2s;
    }
    .interlink-input-row input:focus {
      border-color: var(--primary);
      box-shadow: 0 0 0 2px var(--primary-highlight);
    }
    .double-arrow {
      font-size: 1.5rem;
      color: var(--primary);
      margin: 0 0.5rem;
      user-select: none;
      flex: 0 0 auto;
      text-align: center;
      align-self: center;
    }
    @media (max-width: 600px) {
      .interlink-input-row {
        flex-direction: column;
        align-items: stretch;
      }
      .double-arrow {
        margin: 0.5rem 0;
        align-self: center;
      }
    }
    .interlink-btn-row {
      width: 100%;
      display: flex;
      justify-content: center;
    }
    .interlink-btn {
      padding: 0.7rem 2.2rem;
      font-size: 1.1rem;
      border: none;
      border-radius: 4px;
      background: linear-gradient(90deg, #f53b57, #ffd32a, #3c40c6);
      color: #fff;
      font-weight: 900;
      letter-spacing: 0.5px;
      cursor: pointer;
      box-shadow: 0 0 16px #f53b57, 0 0 16px #3c40c6;
      opacity: 0.95;
      animation: neon-underline 2.5s infinite alternate;
      will-change: filter;
      contain: layout style paint;
      transition: background 0.18s, color 0.18s, box-shadow 0.18s, transform 0.18s;
      -webkit-text-stroke: 1.3px #000;
      text-stroke: 1.3px #000;
      font-family: 'Orbitron', 'Share Tech Mono', monospace;
    }
    .interlink-btn:hover, .interlink-btn:focus {
      background: var(--secondary);
      color: var(--secondary-text);
      transform: translateY(-2px) scale(1.04);
      box-shadow: 0 4px 18px var(--primary-highlight);
    }
    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0,0,0,0);
      border: 0;
    }
    @media (max-width: 900px) {
      .interlinked-section-card {
        max-width: 98vw;
      }
      .interlinked-section-content {
        padding: 1.2rem 1rem 1.5rem 1rem;
      }
      .interlinked-heading-overlay h2 {
        font-size: 1.1rem;
      }
      .interlinked-heading-image-wrapper {
        height: 120px;
      }
    }
    .navbar {
      width: 100vw;
      max-width: 100vw;
      left: 0;
      right: 0;
      top: 0;
      background: rgba(20, 10, 40, 0.92);
      box-shadow: 0 2px 32px 0 #f53b57cc, 0 0px 0px 2px #3c40c6cc;
      min-height: 120px;
      display: flex;
      align-items: center;
      justify-content: center;
      position: sticky;
      z-index: 100;
      margin-bottom: 2rem;
      backdrop-filter: blur(8px);
      border-bottom: 2px solid #f53b57;
      transition: background 0.3s;
    }
    .navbar-content {
      min-height: 120px;
      align-items: center;
      width: 100%;
      max-width: 1100px;
      box-sizing: border-box;
      display: flex;
      gap: 0.5rem;
      justify-content: space-between;
      padding: 0.2rem 1.5rem;
      font-family: 'Orbitron', 'Share Tech Mono', monospace;
    }
    .logo-link {
      display: flex;
      align-items: center;
      margin-right: 1.5rem;
      margin-bottom: 0;
      position: static;
      transition: transform 0.15s, filter 0.2s;
    }
    .logo {
      width: 100px;
      height: 100px;
      border-radius: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      background: var(--neon-yellow);
      box-shadow: 0 0 24px 4px var(--neon-blue), 0 0 8px 2px var(--neon-pink);
      transition: box-shadow 0.2s, background 0.2s, transform 0.2s;
      will-change: transform, box-shadow;
      contain: layout style paint;
    }
    .logo-link:hover .logo {
      box-shadow: 0 0 32px 8px #f53b57, 0 0 16px 4px #3c40c6;
      filter: brightness(1.3) saturate(1.5) drop-shadow(0 0 12px #ffd32a);
      transform: scale(1.08) rotate(-2deg);
      background: var(--primary-highlight);
    }
    .logo img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      display: block;
    }
    .lang-switcher {
      position: fixed;
      top: 1rem;
      right: 1rem;
      z-index: 100;
      display: flex;
      gap: 0.5rem;
      background: var(--background-dark-highlight);
      padding: 0.3rem 0.7rem;
      border-radius: 8px;
      box-shadow: 0 2px 8px var(--overlay-background);
    }
    .lang-switcher a {
      color: var(--neutral-highlight);
      background: var(--background-dark-highlight);
      padding: 0.25rem 0.75rem;
      border-radius: 6px;
      text-decoration: none;
      font-weight: 600;
      font-size: var(--medium-font-size);
      transition: background 0.2s, color 0.2s;
    }
    .lang-switcher a.active, .lang-switcher a:hover {
      background: var(--primary);
      color: var(--primary-text);
    }
    #interlink-result {
      margin-top:2rem;
      max-width:700px;
      background:rgba(44,64,198,0.10);
      border-radius:12px;
      padding:1.5rem;
      color:#ffd32a;
      font-size:1.1rem;
      font-family:'Share Tech Mono','Orbitron',monospace;
      display:none;
      line-height: 1.7;
    }
    #interlink-result a {
      color: var(--primary);
      text-decoration: underline;
      word-break: break-all;
    }
    #interlink-result strong, #interlink-result b {
      color: #fff;
    }
    #interlink-result em, #interlink-result i {
      color: #bae2e2;
    }
    #interlink-result ul, #interlink-result ol {
      margin-left: 1.5em;
      color: #ffd32a;
    }
  </style>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
</head>
<body>
  <%- include('home/navbar-ticker.ejs', { lang }) %>
  <main class="container" role="main">
    <form class="interlink-form" autocomplete="off">
      <input type="hidden" id="lang" name="lang" value="<%= lang %>" />
      <div class="interlink-input-row">
        <div class="input-wrap">
          <label for="inputA" class="sr-only">Input A</label>
          <input id="inputA" name="inputA" type="text" placeholder="Trump" required />
        </div>
        <span class="double-arrow" aria-hidden="true">&#8646;</span>
        <div class="input-wrap">
          <label for="inputB" class="sr-only">Input B</label>
          <input id="inputB" name="inputB" type="text" placeholder="Epstein" required />
        </div>
      </div>
      <div class="interlink-btn-row">
        <button type="submit" class="interlink-btn">Interlink</button>
      </div>
    </form>
    <div id="interlink-result" style="margin-top:2rem; max-width:700px; background:rgba(44,64,198,0.10); border-radius:12px; padding:1.5rem; color:#ffd32a; font-size:1.1rem; font-family:'Share Tech Mono','Orbitron',monospace; display:none;"></div>
  </main>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const form = document.querySelector('.interlink-form');
      const resultDiv = document.getElementById('interlink-result');
      if (form) {
        form.addEventListener('submit', async function(e) {
          e.preventDefault();
          const inputA = form.querySelector('#inputA')?.value;
          const inputB = form.querySelector('#inputB')?.value;
          const lang = form.querySelector('#lang')?.value || 'ro';
          if(resultDiv) {
            resultDiv.style.display = 'block';
            resultDiv.style.color = '#ffd32a';
            resultDiv.innerHTML = '<em>Loading...</em>';
          }
          try {
            const res = await fetch('/api/interlink', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ inputA, inputB, lang })
            });
            if(res.status === 200) {
              const data = await res.json();
              if(resultDiv) {
                resultDiv.style.display = 'block';
                resultDiv.style.color = '#ffd32a';
                resultDiv.innerHTML = data.completion ? marked.parse(data.completion) : '<em>No response.</em>';
              }
            } else {
              if(resultDiv) {
                resultDiv.style.display = 'block';
                resultDiv.style.color = '#ff3f34';
                resultDiv.innerHTML = '<strong>Error:</strong> ' + res.status;
              }
            }
          } catch (err) {
            if(resultDiv) {
              resultDiv.style.display = 'block';
              resultDiv.style.color = '#ff3f34';
              resultDiv.innerHTML = '<strong>Failed to send:</strong> ' + err;
            }
          }
        });
      }
    });
  </script>
</body>
</html> 