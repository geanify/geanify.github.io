<html lang="<%= lang %>">
  <head>
    <meta charset="UTF-8">
    <title>Interlinked - <%= t.title %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
      body {
        background: linear-gradient(135deg, #1a0033 0%, #3c40c6 100%);
        font-family: 'EB Garamond', serif;
        color: #e0e0ff;
        margin: 0;
        min-height: 100vh;
      }
      header {
        background: #3c40c6;
        border-bottom: 8px solid #ffd32a;
        padding: 2rem 0 1rem 0;
        text-align: center;
        box-shadow: 0 4px 24px rgba(44, 24, 200, 0.15);
      }
      header h1 {
        font-family: 'UnifrakturCook', cursive;
        font-size: 3rem;
        color: #ffd32a;
        letter-spacing: 0.1em;
        margin: 0;
        text-shadow: 0 2px 8px #3c40c6, 0 0 2px #ffd32a;
      }
      nav a {
        color: #fff;
        background: #ffd32a;
        border: 2px solid #ffd32a;
        border-radius: 8px;
        padding: 0.5em 1.2em 0.5em 0.5em;
        text-decoration: none;
        font-weight: bold;
        margin-top: 1rem;
        display: inline-flex;
        align-items: center;
        gap: 0.5em;
        box-shadow: 0 2px 8px #3c40c6;
        transition: background 0.2s, color 0.2s;
      }
      nav a img.logo {
        width: 32px;
        height: 32px;
        object-fit: contain;
        display: inline-block;
        margin-right: 0.5em;
        vertical-align: middle;
      }
      nav a:hover {
        background: #3c40c6;
        color: #ffd32a;
      }
      main {
        max-width: 1100px;
        margin: 2rem auto;
        position: relative;
      }
      main:before, main:after {
        content: '';
        display: block;
        position: absolute;
        left: 50%;
        width: 80px;
        height: 80px;
        background: url('/images/interlinked-corner.svg') no-repeat center center/contain;
        opacity: 0.18;
        pointer-events: none;
      }
      main:before {
        top: -40px;
        transform: translateX(-120%);
      }
      main:after {
        bottom: -40px;
        transform: translateX(20%) rotate(180deg);
      }
      .interlinked-section-card {
        background: rgba(44, 64, 198, 0.15);
        border-radius: 18px;
        box-shadow: 0 4px 32px #1a003344;
        margin: 0 auto 2rem auto;
        max-width: 700px;
        padding: 0;
        overflow: hidden;
      }
      .interlinked-heading-image-wrapper {
        width: 100%;
        height: 180px;
        background: #ffd32a;
        display: flex;
        align-items: flex-end;
        justify-content: center;
        position: relative;
      }
      .interlinked-heading-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.85;
        border-bottom: 4px solid #ffd32a;
      }
      .interlinked-heading-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        background: linear-gradient(0deg, #1a0033 80%, transparent 100%);
        padding: 1.2rem 0 0.5rem 0;
        text-align: center;
      }
      .interlinked-heading-overlay h2 {
        color: #ffd32a;
        font-size: 2rem;
        font-family: 'Orbitron', 'Share Tech Mono', monospace;
        margin: 0;
        letter-spacing: 0.08em;
        text-shadow: 0 2px 8px #3c40c6, 0 0 2px #ffd32a;
      }
      .interlinked-section-content {
        padding: 2rem 2.5rem 2.5rem 2.5rem;
        font-size: 1.18rem;
        color: #e0e0ff;
        font-family: 'Share Tech Mono', 'Orbitron', monospace;
        line-height: 1.7;
        text-align: center;
      }
      @media (max-width: 900px) {
        .interlinked-section-card {
          max-width: 98vw;
        }
        .interlinked-section-content {
          padding: 1.2rem 1rem 1.5rem 1rem;
        }
        .interlinked-heading-overlay h2 {
          font-size: 1.5rem;
        }
        .interlinked-heading-image-wrapper {
          height: 120px;
        }
      }
    </style>
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:wght@400;700&family=UnifrakturCook:wght@700&family=Orbitron:wght@700&display=swap" rel="stylesheet">
  </head>
  <body>
    <header>
      <h1>Interlinked</h1>
      <nav>
        <a href="/">
          <img src="/logo.png" alt="Web Herald Logo" class="logo" />
          <span><%= t.title %></span>
        </a>
      </nav>
    </header>
    <main>
      <section class="interlinked-section-card">
        <div class="interlinked-heading-image-wrapper">
          <img src="/images/interlinked.png" alt="Interlinked Heading" class="interlinked-heading-image" />
          <div class="interlinked-heading-overlay">
            <h2>Interlinked Project</h2>
          </div>
        </div>
        <div class="interlinked-section-content">
          <p>A new project exploring the interconnectedness of digital identities, networks, and society. More details coming soon.</p>
        </div>
      </section>
    </main>
  </body>
</html> 